{
    "singleQuote": true,
    "printWidth": 120,
    "tabWidth": 4,
    "trailingComma": "es5",
    "bracketSpacing": true,
    "bracketSameLine": false,
    "arrowParens": "always",
    "endOfLine": "lf",
    "singleAttributePerLine": true,
    "plugins": ["prettier-plugin-astro"],
    "overrides": [
        {
            "files": ["*.ts", "*.astro"],
            "options": {
                "semi": true
            }
        },
        {
            "files": ["*.astro"],
            "options": {
                "parser": "astro"
            }
        }
    ]
}
