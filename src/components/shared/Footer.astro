---
import { TOOLS } from '../../config/tools';

const base = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();
const activeTools = TOOLS.filter((t) => !t.comingSoon);
---

<footer class="w-full bg-white text-slate-500 border-t border-slate-100">
    <!-- Sección principal -->
    <div class="mx-auto max-w-7xl px-6 lg:px-8 py-8 lg:py-14">
        <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4 lg:gap-8">
            <!-- Col 1: Logo + tagline + RRSS -->
            <div class="flex flex-col gap-5">
                <a
                    href={base}
                    class="flex items-center gap-3"
                >
                    <img
                        src={base + 'logo.svg'}
                        alt="Grexia"
                        class="h-9 w-9 shrink-0"
                    />
                    <span
                        class="text-[22px] font-black uppercase tracking-[0.05em] text-secondary"
                        style="font-family: 'Montserrat', 'Proxima Nova', 'Segoe UI', sans-serif;"
                        >Grexia</span
                    >
                </a>
                <p class="text-sm leading-relaxed text-slate-500">
                    Herramientas legales gratuitas para Colombia. Sin registro, sin letra pequeña.
                </p>
                <div class="flex items-center gap-3">
                    <!-- Instagram -->
                    <a
                        href="#"
                        aria-label="Instagram"
                        class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-100 text-slate-500 hover:bg-slate-200 hover:text-secondary transition-colors"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            class="h-5 w-5"
                        >
                            <path
                                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
                            ></path>
                        </svg>
                    </a>
                    <!-- Facebook -->
                    <a
                        href="#"
                        aria-label="Facebook"
                        class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-100 text-slate-500 hover:bg-slate-200 hover:text-secondary transition-colors"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            class="h-5 w-5"
                        >
                            <path
                                d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
                            ></path>
                        </svg>
                    </a>
                    <!-- YouTube -->
                    <a
                        href="#"
                        aria-label="YouTube"
                        class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-100 text-slate-500 hover:bg-slate-200 hover:text-secondary transition-colors"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            class="h-5 w-5"
                        >
                            <path
                                d="M23.495 6.205a3.007 3.007 0 00-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 00.527 6.205a31.247 31.247 0 00-.522 5.805 31.247 31.247 0 00.522 5.783 3.007 3.007 0 002.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 002.088-2.088 31.247 31.247 0 00.5-5.783 31.247 31.247 0 00-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"
                            ></path>
                        </svg>
                    </a>
                </div>
            </div>

            <!-- Col 2: Herramientas -->
            <div class="flex flex-col gap-4">
                <h3 class="text-sm font-bold uppercase tracking-wider text-secondary">Herramientas</h3>
                <ul class="flex flex-col gap-2.5">
                    {
                        activeTools.map((tool) => (
                            <li>
                                <a
                                    href={base + tool.href.landing}
                                    class="text-sm text-slate-500 transition-colors hover:text-secondary"
                                >
                                    {tool.name}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>

            <!-- Col 3: Empresa -->
            <div class="flex flex-col gap-4">
                <h3 class="text-sm font-bold uppercase tracking-wider text-secondary">Empresa</h3>
                <ul class="flex flex-col gap-2.5">
                    <li>
                        <a
                            href={base + '#precios'}
                            class="text-sm text-slate-500 transition-colors hover:text-secondary"
                        >
                            Precios
                        </a>
                    </li>
                    <li>
                        <a
                            href={base + 'empresarial/contacto'}
                            class="text-sm text-slate-500 transition-colors hover:text-secondary"
                        >
                            Plan Empresarial
                        </a>
                    </li>
                    <li>
                        <a
                            href={base + 'ayuda'}
                            class="text-sm text-slate-500 transition-colors hover:text-secondary"
                        >
                            Ayuda
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Col 4: Legal -->
            <div class="flex flex-col gap-4">
                <h3 class="text-sm font-bold uppercase tracking-wider text-secondary">Legal</h3>
                <ul class="flex flex-col gap-2.5">
                    <li>
                        <a
                            href={base + 'ayuda/terminos'}
                            class="text-sm text-slate-500 transition-colors hover:text-secondary"
                        >
                            Términos y Condiciones
                        </a>
                    </li>
                    <li>
                        <a
                            href={base + 'ayuda/privacidad'}
                            class="text-sm text-slate-500 transition-colors hover:text-secondary"
                        >
                            Política de Privacidad
                        </a>
                    </li>
                    <li>
                        <a
                            href={base + 'ayuda/faqs'}
                            class="text-sm text-slate-500 transition-colors hover:text-secondary"
                        >
                            FAQs
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Separador + Copyright -->
    <div class="border-t border-slate-100">
        <div class="mx-auto max-w-7xl px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
            <p class="text-xs text-slate-500">© {currentYear} Grexia. Todos los derechos reservados.</p>
            <p class="text-xs text-slate-500">Hecho con ♥ en Colombia</p>
        </div>
    </div>
</footer>
