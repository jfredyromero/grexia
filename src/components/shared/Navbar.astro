---
import { TOOLS } from '../../config/tools';
import type { ToolSlug } from '../../config/tools';

interface Props {
    variant?: 'home' | 'tool-landing' | 'tool-form';
    activeTool?: ToolSlug;
}

const { variant = 'home', activeTool } = Astro.props;

const activeCfg = activeTool ? TOOLS.find((t) => t.slug === activeTool) : undefined;
---

<header class="sticky top-0 z-50 w-full border-b border-slate-200 bg-white/90 backdrop-blur-md">
    <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-6 lg:px-8">
        <!-- Logo -->
        <a
            href="/"
            class="flex items-center gap-3"
        >
            <img
                src="/logo.svg"
                alt="Lexia"
                class="h-9 w-9 shrink-0"
            />
            <div class="h-7 w-px bg-slate-200"></div>
            <span
                class="text-xl font-bold uppercase tracking-[0.05em] text-[#112A46]"
                style="font-family: 'Montserrat', 'Proxima Nova', 'Segoe UI', sans-serif;"
                >Lexia</span
            >
        </a>

        <!-- Desktop: nav links + CTA (right side) -->
        <div class="hidden md:flex items-center gap-8">
            <nav class="flex items-center gap-8">
                <a
                    href="/#herramientas"
                    class="text-sm font-medium text-slate-700 transition-colors hover:text-secondary"
                >
                    Herramientas
                </a>
                <a
                    href="/#precios"
                    class="text-sm font-medium text-slate-700 transition-colors hover:text-secondary"
                >
                    Precios
                </a>
            </nav>

            <div class="h-5 w-px bg-slate-200"></div>

            <div class="flex items-center gap-3">
                <a
                    href="/asesoria/checkout"
                    class="flex h-11 items-center justify-center rounded-full border border-slate-200 bg-white px-5 text-sm font-bold text-slate-700 transition-all hover:bg-slate-50 hover:border-slate-300"
                >
                    Agendar Asesoría
                </a>

                {
                    variant === 'home' && (
                        <a
                            href="/#herramientas"
                            class="flex h-11 items-center justify-center gap-1.5 rounded-full bg-primary px-6 text-sm font-bold text-white shadow-md shadow-primary/20 transition-all hover:bg-primary-hover hover:-translate-y-px"
                        >
                            Ver herramientas
                            <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                        </a>
                    )
                }

                {
                    variant === 'tool-landing' && activeCfg && (
                        <a
                            href={activeCfg.href.form}
                            class="flex h-11 items-center justify-center gap-1.5 rounded-full bg-primary px-6 text-sm font-bold text-white shadow-md shadow-primary/20 transition-all hover:bg-primary-hover hover:-translate-y-px"
                        >
                            Generar {activeCfg.shortName}
                            <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                        </a>
                    )
                }
            </div>
        </div>

        <!-- Mobile: hamburger button -->
        <button
            id="mobile-menu-btn"
            class="md:hidden flex h-10 w-10 items-center justify-center rounded-full bg-slate-100 text-slate-900 transition-colors hover:bg-slate-200"
            aria-label="Abrir menú"
            aria-expanded="false"
            aria-controls="mobile-menu"
        >
            <span
                class="material-symbols-outlined"
                id="menu-icon"
                >menu</span
            >
        </button>
    </div>

    <!-- Mobile menu drawer -->
    <div
        id="mobile-menu"
        class="md:hidden hidden border-t border-slate-100 bg-white/95 backdrop-blur-md"
    >
        <div class="mx-auto max-w-7xl px-6 py-4 flex flex-col gap-1">
            <a
                href="/#herramientas"
                class="mobile-menu-link flex items-center gap-3 rounded-lg px-3 py-3 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-50 hover:text-secondary"
            >
                <span class="material-symbols-outlined text-[18px] text-slate-400">handyman</span>
                Herramientas
            </a>
            <a
                href="/#precios"
                class="mobile-menu-link flex items-center gap-3 rounded-lg px-3 py-3 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-50 hover:text-secondary"
            >
                <span class="material-symbols-outlined text-[18px] text-slate-400">sell</span>
                Precios
            </a>
            <a
                href="/asesoria/checkout"
                class="flex items-center gap-3 rounded-lg px-3 py-3 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-50 hover:text-secondary"
            >
                <span class="material-symbols-outlined text-[18px] text-slate-400">calendar_month</span>
                Agendar Asesoría
            </a>

            <div class="mt-3 pt-3 border-t border-slate-100 flex flex-col gap-2">
                {
                    variant === 'home' && (
                        <a
                            href="/#herramientas"
                            class="mobile-menu-link flex h-12 items-center justify-center gap-1.5 rounded-full bg-primary text-sm font-bold text-white shadow-md shadow-primary/20"
                        >
                            Ver herramientas
                            <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                        </a>
                    )
                }
                {
                    variant === 'tool-landing' && activeCfg && (
                        <a
                            href={activeCfg.href.form}
                            class="flex h-12 items-center justify-center gap-1.5 rounded-full bg-primary text-sm font-bold text-white shadow-md shadow-primary/20"
                        >
                            Generar {activeCfg.shortName}
                            <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                        </a>
                    )
                }
            </div>
        </div>
    </div>
</header>

<script>
    const btn = document.getElementById('mobile-menu-btn')!;
    const menu = document.getElementById('mobile-menu')!;
    const icon = document.getElementById('menu-icon')!;

    btn.addEventListener('click', () => {
        const isOpen = !menu.classList.contains('hidden');
        menu.classList.toggle('hidden', isOpen);
        icon.textContent = isOpen ? 'menu' : 'close';
        btn.setAttribute('aria-expanded', String(!isOpen));
    });

    // Close on link click
    menu.querySelectorAll<HTMLAnchorElement>('.mobile-menu-link').forEach((link) => {
        link.addEventListener('click', () => {
            menu.classList.add('hidden');
            icon.textContent = 'menu';
            btn.setAttribute('aria-expanded', 'false');
        });
    });
</script>
