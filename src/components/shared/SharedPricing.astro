---
const base = import.meta.env.BASE_URL;

const plans = [
    {
        id: 'free',
        badge: 'Siempre gratis',
        badgeColor: 'bg-slate-100 text-slate-600',
        name: 'Gratis',
        price: '$0',
        period: 'COP · Sin registro',
        description: 'Genera y descarga documentos sin límite, sin crear cuenta.',
        highlighted: false,
        features: [
            { text: 'Generación ilimitada de documentos', included: true },
            { text: 'Todos los documentos disponibles en Lexia', included: true },
            { text: 'Descarga en PDF sin registro', included: true },
            { text: 'Marca de agua Lexia en el documento', included: true, warning: true },
            { text: 'Sin asesoría legal incluida', included: false },
        ],
        cta: 'Empezar gratis',
        ctaIcon: 'arrow_forward',
        ctaHref: base + '#herramientas',
    },
    {
        id: 'acompanamiento',
        badge: '★ Recomendado',
        badgeColor: 'bg-white/15 text-white',
        name: 'Acompañamiento',
        price: '$59.900',
        period: 'COP · primera sesión',
        description: 'Para quien necesita orientación legal continua en un caso particular.',
        highlighted: true,
        features: [
            { text: 'Sesión inicial de estudio de viabilidad', included: true },
            { text: 'Diagnóstico y hoja de ruta legal', included: true },
            { text: 'Precio del acompañamiento ajustado al caso', included: true },
            { text: 'Acompañamiento en proceso legal completo', included: true },
            { text: 'Templates empresariales personalizados', included: false },
        ],
        cta: 'Agendar primera sesión',
        ctaIcon: 'calendar_month',
        ctaHref: base + 'asesoria/checkout',
    },
    {
        id: 'empresarial',
        badge: '✦ Empresas',
        badgeColor: 'bg-slate-100 text-slate-700',
        name: 'Empresarial',
        price: '$119.000',
        period: 'COP / mes',
        description: 'Para empresas que generan documentos en volumen con branding propio.',
        highlighted: false,
        features: [
            { text: 'Generación ilimitada de documentos', included: true },
            { text: 'Templates con tu logo y sin marca de agua', included: true },
            { text: 'Múltiples usuarios', included: true },
            { text: 'Soporte prioritario', included: true },
            { text: 'Asesorías legales no incluidas', included: false },
        ],
        cta: 'Contratar plan',
        ctaIcon: 'arrow_forward',
        ctaHref: base + 'empresarial/contacto',
    },
];
---

<section
    class="w-full bg-background-light py-8 lg:py-14"
    id="precios"
>
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <!-- Section Header -->
        <div class="text-center mb-14">
            <h2 class="text-3xl font-black tracking-tight text-secondary sm:text-4xl">Elige tu plan</h2>
            <p class="mt-3 max-w-xl mx-auto text-lg text-slate-600">Empieza gratis. Escala cuando lo necesites.</p>
        </div>

        <!-- Cards -->
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-3 lg:gap-6 max-w-5xl mx-auto items-start">
            {
                plans.map((plan) => (
                    <div
                        class={[
                            'relative flex flex-col gap-6 rounded-lg p-8 overflow-hidden',
                            plan.highlighted
                                ? 'bg-secondary shadow-xl shadow-secondary/25 ring-2 ring-primary'
                                : 'bg-white border border-slate-200 shadow-sm',
                        ].join(' ')}
                    >
                        {plan.highlighted && (
                            <div class="absolute -top-16 -right-16 h-48 w-48 rounded-full bg-primary/10 blur-2xl pointer-events-none" />
                        )}

                        {/* Badge + Name */}
                        <div class="relative">
                            <span
                                class={[
                                    'inline-flex items-center rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wide',
                                    plan.badgeColor,
                                ].join(' ')}
                            >
                                {plan.badge}
                            </span>
                            <h3
                                class={[
                                    'mt-4 text-2xl font-black',
                                    plan.highlighted ? 'text-white' : 'text-secondary',
                                ].join(' ')}
                            >
                                {plan.name}
                            </h3>
                            <p
                                class={['mt-1 text-sm', plan.highlighted ? 'text-slate-300' : 'text-slate-600'].join(
                                    ' '
                                )}
                            >
                                {plan.description}
                            </p>
                        </div>

                        {/* Price */}
                        <div class="relative flex items-end gap-1.5">
                            <span
                                class={['text-4xl font-black', plan.highlighted ? 'text-white' : 'text-secondary'].join(
                                    ' '
                                )}
                            >
                                {plan.price}
                            </span>
                            <span
                                class={['text-sm pb-1', plan.highlighted ? 'text-slate-300' : 'text-slate-600'].join(
                                    ' '
                                )}
                            >
                                {plan.period}
                            </span>
                        </div>

                        {/* Features */}
                        <ul class="relative flex flex-col gap-3">
                            {plan.features.map((feature) => (
                                <li
                                    class={[
                                        'flex items-start gap-2.5 text-sm',
                                        feature.included
                                            ? plan.highlighted
                                                ? 'text-slate-300'
                                                : 'text-slate-700'
                                            : plan.highlighted
                                              ? 'text-slate-500 line-through'
                                              : 'text-slate-400 line-through',
                                    ].join(' ')}
                                >
                                    <span
                                        class={[
                                            'material-symbols-outlined text-[18px] mt-0.5 shrink-0',
                                            feature.included
                                                ? (feature as { warning?: boolean }).warning
                                                    ? 'text-amber-400'
                                                    : plan.highlighted
                                                      ? 'text-blue-400'
                                                      : 'text-primary'
                                                : plan.highlighted
                                                  ? 'text-slate-500'
                                                  : 'text-slate-400',
                                        ].join(' ')}
                                    >
                                        {feature.included
                                            ? (feature as { warning?: boolean }).warning
                                                ? 'warning'
                                                : 'check_circle'
                                            : 'cancel'}
                                    </span>
                                    {feature.text}
                                </li>
                            ))}
                        </ul>

                        {/* CTA */}
                        <a
                            href={plan.ctaHref}
                            data-plan={plan.id}
                            class={[
                                'relative mt-auto flex h-12 items-center justify-center gap-1.5 rounded-full text-sm font-bold transition-all hover:-translate-y-px',
                                plan.highlighted
                                    ? 'bg-primary text-white shadow-md shadow-primary/20 hover:bg-primary-hover'
                                    : plan.id === 'empresarial'
                                      ? 'bg-secondary text-white hover:bg-slate-800 border border-slate-700'
                                      : 'bg-primary text-white shadow-md shadow-primary/20 hover:bg-primary-hover',
                            ].join(' ')}
                        >
                            {plan.cta}
                            <span class="material-symbols-outlined text-[18px]">{plan.ctaIcon}</span>
                        </a>
                    </div>
                ))
            }
        </div>

        <!-- Bottom note -->
        <p class="text-center text-xs text-slate-500 mt-8">
            El plan Empresarial incluye acceso a toda la suite de documentos con branding propio. El precio de
            acompañamiento se acuerda en la primera sesión según la complejidad del caso.
        </p>
    </div>
</section>

<script>
    document.querySelectorAll<HTMLAnchorElement>('[data-plan]').forEach((el) => {
        el.addEventListener('click', () => {
            const plan = el.dataset.plan;
            if (plan === 'empresarial') {
                localStorage.setItem('lexia_plan', plan);
            } else {
                localStorage.removeItem('lexia_plan');
            }
        });
    });
</script>
