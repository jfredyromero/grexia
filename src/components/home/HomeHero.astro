---
const base = import.meta.env.BASE_URL;

const trustBadges = [
    { icon: 'check_circle', label: 'Gratis · Sin registro' },
    { icon: 'verified', label: 'Válido en Colombia' },
    { icon: 'download', label: 'Descarga en PDF' },
