---
import { TOOLS } from '../../config/tools';

interface Props {
    showHeader?: boolean;
}

const { showHeader = true } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section
    id="herramientas"
    class="w-full bg-white py-8 lg:py-14"
>
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
        {
            showHeader && (
                <div class="text-center mb-14">
                    <span class="inline-flex items-center gap-1.5 rounded-full bg-primary/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-secondary">
                        <span class="material-symbols-outlined text-primary text-[16px]">apps</span>
                        Herramientas
                    </span>
                    <h2 class="mt-4 text-3xl font-black tracking-tight text-secondary sm:text-4xl">
                        ¿Qué quieres generar hoy?
                    </h2>
                    <p class="mt-3 max-w-xl mx-auto text-lg text-slate-600">
                        Selecciona el documento que necesitas. Todos gratuitos, sin registro.
                    </p>
                </div>
            )
        }

        <!-- Tool Cards -->
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 max-w-4xl mx-auto">
            {
                TOOLS.map((tool) => (
                    <a
                        href={tool.comingSoon ? '#' : base + tool.href.landing}
                        class={[
                            'group relative flex flex-col gap-5 rounded-lg border p-8 transition-all',
                            tool.comingSoon
                                ? 'border-slate-100 bg-slate-50 cursor-not-allowed opacity-60'
                                : 'border-slate-200 bg-white shadow-sm hover:shadow-md hover:-translate-y-1 hover:border-primary/30',
                        ].join(' ')}
                    >
                        {/* Icon */}
                        <div
                            class={[
                                'flex h-14 w-14 items-center justify-center rounded-lg',
                                tool.comingSoon
                                    ? 'bg-slate-200'
                                    : 'bg-primary/10 group-hover:bg-primary/20 transition-colors',
                            ].join(' ')}
                        >
                            <span
                                class={[
                                    'material-symbols-outlined text-[32px]',
                                    tool.comingSoon ? 'text-slate-400' : 'text-primary',
                                ].join(' ')}
                            >
                                {tool.icon}
                            </span>
                        </div>

                        {/* Info */}
                        <div class="flex flex-col gap-2 flex-1">
                            <div class="flex items-center gap-2">
                                <h3 class="text-lg font-bold text-secondary">{tool.name}</h3>
                                {tool.comingSoon && (
                                    <span class="inline-flex items-center rounded-full bg-slate-200 px-2 py-0.5 text-xs font-semibold text-slate-700">
                                        Próximamente
                                    </span>
                                )}
                            </div>
                            <p class="text-sm text-slate-600 leading-relaxed">{tool.description}</p>
                        </div>

                        {/* Legal basis tag */}
                        <div class="flex items-center justify-between">
                            <span class="text-xs font-semibold text-slate-500">{tool.legalBasis}</span>
                            {!tool.comingSoon && (
                                <span class="material-symbols-outlined text-slate-400 text-[20px] group-hover:text-primary transition-colors">
                                    arrow_forward
                                </span>
                            )}
                        </div>
                    </a>
                ))
            }
        </div>
    </div>
</section>
