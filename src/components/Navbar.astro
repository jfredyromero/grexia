---
const CALENDAR_URL = 'https://calendar.google.com/calendar/appointments/YOUR_PLACEHOLDER';

const navLinks = [
    { label: '¿Cómo funciona?', href: '/#como-funciona', external: false },
    { label: 'Agendar Asesoría', href: CALENDAR_URL, external: true },
];
---

<header class="sticky top-0 z-50 w-full border-b border-slate-200 bg-white/90 backdrop-blur-md">
    <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-6 lg:px-8">
        <!-- Logo -->
        <a
            href="/"
            class="flex items-center gap-3"
        >
            <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-9 w-9 flex-shrink-0">
                <line x1="13" y1="17" x2="4" y2="31" stroke="#5BBDB9" stroke-width="5" stroke-linecap="round"/>
                <g transform="rotate(-33, 19, 10)">
                    <rect x="12" y="7" width="15" height="6.5" rx="1.5" fill="#1B3070"/>
                    <rect x="12.5" y="8.2" width="3.2" height="1.3" rx="0.4" fill="white"/>
                    <rect x="12.5" y="10.2" width="3.2" height="1.3" rx="0.4" fill="white"/>
                </g>
                <rect x="22.5" y="9.5" width="9.5" height="2.2" rx="0.5" fill="#1B3070"/>
                <rect x="25.5" y="11.7" width="3.5" height="13" fill="#1B3070"/>
                <rect x="22.5" y="24.7" width="9.5" height="2.2" rx="0.5" fill="#1B3070"/>
                <rect x="13" y="28.5" width="10.5" height="2" rx="1" fill="#1B3070"/>
            </svg>
            <div class="h-7 w-px bg-slate-200"></div>
            <span class="text-xl font-black tracking-tight text-secondary">Lexia</span>
        </a>

        <!-- Navigation Links (Desktop) -->
        <nav class="hidden md:flex items-center gap-8">
            {
                navLinks.map((link) => (
                    <a
                        class="text-sm font-medium text-slate-600 transition-colors hover:text-secondary"
                        href={link.href}
                        target={link.external ? '_blank' : undefined}
                        rel={link.external ? 'noopener noreferrer' : undefined}
                    >
                        {link.label}
                    </a>
                ))
            }
        </nav>

        <!-- Action Buttons -->
        <div class="flex items-center gap-3">
            <a
                href={CALENDAR_URL}
                target="_blank"
                rel="noopener noreferrer"
                class="hidden sm:flex h-11 items-center justify-center rounded-full border border-slate-200 bg-white px-5 text-sm font-bold text-slate-700 transition-all hover:bg-slate-50 hover:border-slate-300"
            >
                Agendar Asesoría
            </a>
            <a
                href="/minuta"
                class="flex h-11 items-center justify-center gap-1.5 rounded-full bg-primary px-6 text-sm font-bold text-white shadow-md shadow-primary/20 transition-all hover:bg-primary-hover hover:translate-y-[-1px]"
            >
                Generar minuta
                <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
            </a>
            <!-- Mobile Menu Button -->
            <button
                class="md:hidden flex h-10 w-10 items-center justify-center rounded-full bg-slate-100 text-slate-900"
                aria-label="Abrir menú"
            >
                <span class="material-symbols-outlined">menu</span>
            </button>
        </div>
    </div>
</header>
