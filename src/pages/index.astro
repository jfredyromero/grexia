---
import Layout from '../layouts/Layout.astro';
import HomeHero from '../components/home/HomeHero.astro';
import ToolGrid from '../components/home/ToolGrid.astro';
import SharedPricing from '../components/shared/SharedPricing.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

const homeSchema = {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Grexia',
    url: Astro.site?.href ?? 'https://grexia.co/',
    description:
        'Genera contratos de arrendamiento, pagarés, tutelas y más. Documentos con validez legal en Colombia, redactados por abogados. Gratis y sin registro.',
    publisher: {
        '@type': 'Organization',
        name: 'Grexia',
        url: Astro.site?.href ?? 'https://grexia.co/',
        sameAs: ['https://grexia.co'],
    },
};
---

<Layout
    title="Grexia - Plataforma Legal para Colombia"
    description="Genera contratos de arrendamiento, pagarés, tutelas y más. Documentos con validez legal en Colombia, redactados por abogados. Gratis y sin registro."
    schema={homeSchema}
>
    <HomeHero />
    <ToolGrid />
    <SharedPricing />
    <WhatsAppButton />
</Layout>
