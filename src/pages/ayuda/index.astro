---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/shared/Navbar.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';

const base = import.meta.env.BASE_URL;

const secciones = [
    {
        href: base + 'ayuda/faqs',
        icon: 'quiz',
        titulo: 'Preguntas Frecuentes',
        descripcion: 'Todo lo que necesitas saber sobre cómo funciona Grexia, sus herramientas y documentos.',
    },
    {
        href: base + 'ayuda/terminos',
        icon: 'gavel',
        titulo: 'Términos y Condiciones',
        descripcion:
            'Las condiciones de uso de la plataforma, propiedad intelectual y limitaciones de responsabilidad.',
    },
    {
        href: base + 'ayuda/privacidad',
        icon: 'shield',
        titulo: 'Política de Privacidad',
        descripcion: 'Cómo tratamos tus datos personales conforme a la Ley 1581 de 2012.',
    },
];
---

<Layout title="Ayuda · Grexia | Documentos Legales para Colombia">
    <Navbar variant="home" />

    <main class="grow w-full">
        <!-- ─── HERO ──────────────────────────────────────────────────────── -->
        <section class="bg-white pt-14 pb-0 lg:pt-20">
            <div class="mx-auto max-w-4xl px-6 lg:px-8 text-center">
                <h1 class="text-4xl font-black tracking-tight text-secondary sm:text-5xl lg:text-6xl leading-tight">
                    Centro de
                    <span class="relative whitespace-nowrap">
                        Ayuda
                        <span class="absolute bottom-1 left-0 h-3 w-full bg-primary/40 rounded-full"></span>
                    </span>
                </h1>
                <p class="mx-auto mt-8 max-w-xl text-lg text-slate-600">
                    Encuentra respuestas a tus preguntas, los términos del servicio y nuestra política de privacidad.
                </p>
            </div>
        </section>

        <!-- ─── CARDS DE NAVEGACIÓN ───────────────────────────────────────── -->
        <section class="bg-white py-16 lg:py-24">
            <div class="mx-auto max-w-5xl px-6 lg:px-8">
                <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
                    {
                        secciones.map((s) => (
                            <a
                                href={s.href}
                                class="group flex flex-col rounded-lg border border-slate-200 bg-white p-8 shadow-sm transition-all hover:shadow-md hover:-translate-y-0.5"
                            >
                                <span class="mb-5 flex h-11 w-11 items-center justify-center rounded-full bg-primary/10">
                                    <span class="material-symbols-outlined text-[22px] text-primary">{s.icon}</span>
                                </span>
                                <h2 class="text-lg font-black text-secondary leading-snug">{s.titulo}</h2>
                                <p class="mt-2 text-sm text-slate-600 leading-relaxed flex-1">{s.descripcion}</p>
                                <div class="mt-6 flex items-center gap-1 text-sm font-bold text-primary">
                                    Ver más
                                    <span class="material-symbols-outlined text-[16px] transition-transform group-hover:translate-x-0.5">
                                        arrow_forward
                                    </span>
                                </div>
                            </a>
                        ))
                    }
                </div>
            </div>
        </section>
    </main>

    <WhatsAppButton />
</Layout>
