---
import Layout from '../../layouts/Layout.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import Breadcrumb from '../../components/shared/Breadcrumb.astro';
import FAQAccordion from '../../components/shared/FAQAccordion.tsx';
import { TOOLS } from '../../config/tools';

const base = import.meta.env.BASE_URL;
const tool = TOOLS.find((t) => t.slug === 'pagare')!;

const trustBadges = [
    { icon: 'balance', label: 'Marco legal vigente' },
    { icon: 'lock', label: 'Sin registro' },
    { icon: 'picture_as_pdf', label: 'PDF en 1 minuto' },
];

const socialAvatars = [
    {
        src: 'https://lh3.googleusercontent.com/aida-public/AB6AXuD5V-on_7keAJEftPazMB7vJ67iatf4qd4WOg_ZLAGyQBUYYmpcgWK5CelWduBdraqtPEVMpbZacLQTptHErkMPUSMqVXJe326yqQ1W5TwXEGPS4jEK_qNcJlia7lnzWXHb8dHj4yFQ0yb8dgypVkMEydK7l4KuqFSfMe08sorNHA100WBaGKGVLRDnkqDwuhJaz29ykI2nxkBUGnMcdVoXgJQJLSjQy3dkBNGn3kCa3dXugbVN6ZcyTay7ASuwwRvKF5m__5lVmKDy',
        alt: 'Usuaria de Grexia',
    },
    {
        src: 'https://lh3.googleusercontent.com/aida-public/AB6AXuCfp-jh4m6Wbqi9eNLW5obsxwye-auLWzPod3k8AJEROlnlaC_1aesC1FHe7w3PXdQekpmc1AW1_i3T5me0j8M5OUwqa88kbLcNPK3-4JyenI6zUb4QR6Av2Yh4wh10lu4brK_rCWq_2EIcu93vRZ4rWuRPfxhmVwSAVnZVNXWprqEEhh8Pv6fQZO5Hir-sQmpAv-PUqk9Lx0iPvBHpG-Ufxf9VoI2PTL81xeLGJ_9uZ5UabQYR-HFeNlBSdNJxQeWQyU2Tj0VbSAw9',
        alt: 'Usuario de Grexia',
    },
    {
        src: 'https://lh3.googleusercontent.com/aida-public/AB6AXuDCX5Y3IuUrv_PQkgw7I4x0hIq5GvqM4mNZH8Nf77tl1GcPXLaCsLSP2o-hJE_jkQBylIIrWbA_Agy1XvGpz_f8DUANpGrude4HanBLTVn0rjk9MH1DWXBs_2XcoV0BjA2Jv0TSycQXYoMDCFQ6jRTvQ7EqpI_UR5w-Hc1GzrtD-_-1gqsnysbzsx96QlqhDIlsLbggTZolxZyvIOnJ4GSC_Nr2qTSas446QFjH9RInxio5Jobdsm1Lu_97Tf-dswOGBLAidqyvqKbw',
        alt: 'Usuario de Grexia',
    },
];

const faqPagare = [
    {
        question: '¿Un pagaré escrito en una servilleta o en papel común tiene validez legal?',
        answer: 'Sí, siempre que cumpla con los requisitos del artículo 621 y 709 del Código de Comercio: mención del derecho incorporado, firma del otorgante, promesa incondicional de pagar una suma determinada de dinero, nombre del beneficiario, indicación de ser pagadero a la orden o al portador, y forma de vencimiento. La ley no exige un formato específico, pero si falta alguno de estos elementos el documento pierde su carácter de título valor y no podrás cobrarlo mediante proceso ejecutivo.',
    },
    {
        question: '¿Qué diferencia hay entre un pagaré y una letra de cambio?',
        answer: 'En el pagaré quien lo firma hace una promesa de pagar una suma de dinero. En la letra de cambio se da una orden a un tercero para que pague. El pagaré involucra solo dos partes (acreedor y deudor) y no requiere aceptación: el deudor se obliga directamente al firmarlo. La letra de cambio puede involucrar hasta tres personas (girador, girado y beneficiario) y requiere aceptación del girado. Ambos son títulos valores regidos por el Código de Comercio.',
    },
    {
        question: '¿En cuánto tiempo prescribe un pagaré en Colombia?',
        answer: 'La acción cambiaria directa contra el deudor principal del pagaré prescribe en tres (3) años contados desde la fecha de vencimiento, según el artículo 789 del Código de Comercio. Si el pagaré no tiene fecha de vencimiento, los tres años se cuentan desde la fecha en que el acreedor presenta el título para el pago. Pasado ese plazo pierdes el derecho de cobrarlo por vía ejecutiva, aunque la obligación natural subsiste.',
    },
    {
        question: '¿El pagaré necesita autenticación ante notario para ser válido?',
        answer: 'No. La ley no exige autenticar el pagaré ante notario para que tenga validez como título valor. Sin embargo, autenticar la firma del deudor es altamente recomendable porque evita que luego alegue falsedad de la firma o alteración del documento en el proceso ejecutivo. El costo de autenticar es bajo comparado con el riesgo de perder el cobro por una objeción sobre la firma.',
    },
    {
        question: '¿Puedo cobrar intereses en un pagaré y cuál es el límite legal?',
        answer: 'Sí. Puedes pactar intereses remuneratorios (durante el plazo) y moratorios (por incumplimiento). El artículo 884 del Código de Comercio establece que si las partes no pactan interés moratorio, será una y media veces el interés bancario corriente. El límite máximo legal es la tasa de usura certificada mensualmente por la Superintendencia Financiera: para enero de 2026 es 24,36% efectivo anual para crédito de consumo y ordinario. Si cobras por encima, pierdes todos los intereses.',
    },
    {
        question: '¿Qué pasa si firmo un pagaré en blanco?',
        answer: 'El artículo 622 del Código de Comercio permite los pagarés en blanco, pero exige que el acreedor los diligencie conforme a las instrucciones del suscriptor, que deben constar por escrito en una carta de instrucciones. Si firmas un pagaré sin carta de instrucciones escrita, te expones a que se diligencie por un monto superior, una fecha distinta o condiciones que no acordaste. En la práctica es uno de los mayores riesgos para el deudor y la Corte Constitucional ha advertido sobre sus abusos.',
    },
];

const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqPagare.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: { '@type': 'Answer', text: faq.answer },
    })),
};
---

<Layout
    title="Pagaré en Colombia: Guía Completa del Título Valor - Grexia"
    description="Aprende qué es un pagaré, los requisitos del Art. 709 del Código de Comercio, la prescripción de 3 años y los riesgos de firmarlo mal. Genera el tuyo gratis en Grexia."
    schema={faqSchema}
>
    <main class="grow w-full">
        <!-- ─── HERO ──────────────────────────────────────────────────────── -->
        <section class="grow flex items-center justify-center">
            <div class="relative w-full max-w-7xl px-6 lg:px-8 py-8 lg:py-14">
                <!-- Breadcrumb -->
                <div class="mb-10">
                    <Breadcrumb items={[{ label: 'Guías', href: base + 'guias' }, { label: 'Pagaré' }]} />
                </div>

                <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-20 items-center">
                    <!-- Izquierda: texto -->
                    <div class="flex flex-col gap-8 order-2 lg:order-1">
                        <!-- Trust Badges -->
                        <div class="hidden lg:flex flex-wrap gap-3">
                            {
                                trustBadges.map((badge) => (
                                    <div class="flex items-center gap-1.5 rounded-full bg-white border border-slate-200 px-3 py-1.5 shadow-sm">
                                        <span class="material-symbols-outlined text-primary text-[20px] font-bold">
                                            {badge.icon}
                                        </span>
                                        <span class="text-xs font-semibold text-slate-700 uppercase tracking-wide">
                                            {badge.label}
                                        </span>
                                    </div>
                                ))
                            }
                        </div>

                        <!-- H1 -->
                        <div class="space-y-6">
                            <h1
                                class="text-4xl font-black leading-[1.1] tracking-tight text-secondary sm:text-5xl xl:text-6xl"
                            >
                                Todo sobre el
                                <span class="relative whitespace-nowrap text-secondary">
                                    pagaré
                                    <span class="absolute bottom-1 left-0 -z-10 h-3 w-full bg-primary/40 rounded-full"
                                    ></span>
                                </span>
                                en Colombia
                            </h1>
                            <p class="max-w-lg text-lg text-slate-600 leading-relaxed">
                                Entiende qué es un título valor, qué dice el Código de Comercio y por qué un pagaré mal
                                diligenciado puede convertirse en tu peor deuda. Y al final, genera el tuyo gratis en
                                minutos.
                            </p>
                        </div>

                        <!-- CTAs -->
                        <div class="flex flex-col sm:flex-row gap-4 pt-2">
                            <a
                                href={base + tool.href.form}
                                class="flex h-14 items-center justify-center gap-2 rounded-full bg-primary px-8 text-base font-bold text-white shadow-md shadow-primary/20 transition-all hover:-translate-y-0.5 hover:bg-primary-hover hover:shadow-lg active:translate-y-0"
                            >
                                Generar pagaré gratis
                                <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
                            </a>
                            <a
                                href={base + 'asesoria/checkout'}
                                class="flex h-14 items-center justify-center rounded-full bg-white border border-slate-200 px-8 text-base font-bold text-slate-700 shadow-sm transition-all hover:bg-slate-50 hover:border-slate-300"
                            >
                                Hablar con un abogado
                            </a>
                        </div>

                        <!-- Social Proof -->
                        <div class="flex items-center gap-4 pt-6 border-t border-slate-200 mt-2">
                            <div class="flex -space-x-4">
                                {
                                    socialAvatars.map((a) => (
                                        <img
                                            alt={a.alt}
                                            class="h-12 w-12 rounded-full border-2 border-white object-cover"
                                            src={a.src}
                                        />
                                    ))
                                }
                                <div
                                    class="flex h-12 w-12 items-center justify-center rounded-full border-2 border-white bg-secondary text-xs font-bold text-white"
                                >
                                    +1.2k
                                </div>
                            </div>
                            <div class="flex flex-col justify-center">
                                <div class="flex text-yellow-400 text-sm">
                                    {
                                        Array.from({ length: 5 }).map(() => (
                                            <span class="material-symbols-outlined text-[18px]">star</span>
                                        ))
                                    }
                                </div>
                                <p class="text-sm font-medium text-slate-600">
                                    Más de <span class="font-bold text-secondary">3.200 documentos</span> generados
                                </p>
                            </div>
                        </div>

                        <!-- Legal basis -->
                        <p class="text-sm text-slate-500 -mt-4">
                            Conforme a
                            <strong class="text-slate-700">los artículos 621, 709 y 789 del Código de Comercio</strong>
                        </p>
                    </div>

                    <!-- Derecha: imagen -->
                    <div class="relative hidden lg:block order-1 lg:order-2">
                        <div
                            class="relative w-full aspect-4/5 md:aspect-square lg:aspect-4/5 overflow-hidden rounded-[2.5rem] bg-slate-100 shadow-2xl"
                        >
                            <img
                                alt="Pagaré como título valor en Colombia"
                                class="h-full w-full object-cover object-center"
                                src={tool.heroImage}
                            />
                            <div class="absolute inset-0 bg-linear-to-t from-secondary/20 to-transparent"></div>

                            <!-- Glass Widget: abogado -->
                            <div
                                class="glass-widget absolute top-8 right-6 flex max-w-65 flex-col gap-3 rounded-lg p-4 animate-[fade-in-up_1s_ease-out_0.5s_backwards]"
                            >
                                <div class="flex items-center gap-3">
                                    <div class="relative">
                                        <div
                                            class="h-10 w-10 rounded-full bg-primary flex items-center justify-center border border-white overflow-hidden"
                                        >
                                            <img
                                                alt={tool.heroLawyerName}
                                                class="h-full w-full object-cover"
                                                src={tool.heroLawyerAvatar}
                                            />
                                        </div>
                                        <div
                                            class="absolute bottom-0 right-0 h-3 w-3 rounded-full bg-green-500 border-2 border-white"
                                        >
                                        </div>
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="text-sm font-bold text-slate-800">{tool.heroLawyerName}</span>
                                        <span class="text-xs text-slate-700">{tool.heroLawyerSpecialty}</span>
                                    </div>
                                </div>
                                <div
                                    class="rounded-xl bg-white/60 p-2 text-xs text-slate-700 leading-snug backdrop-blur-sm"
                                >
                                    "{tool.heroChat}"
                                </div>
                            </div>

                            <!-- Glass Widget: guía badge -->
                            <div
                                class="glass-widget absolute bottom-8 left-6 flex items-center gap-3 rounded-full py-3 px-5 pr-8"
                            >
                                <div
                                    class="flex h-10 w-10 items-center justify-center rounded-full bg-primary text-white"
                                >
                                    <span class="material-symbols-outlined text-[24px]">menu_book</span>
                                </div>
                                <div>
                                    <p class="text-xs text-slate-700 font-medium uppercase tracking-wider">
                                        Guía completa
                                    </p>
                                    <p class="text-sm font-bold text-slate-800">Normativa vigente</p>
                                </div>
                            </div>
                        </div>

                        <!-- Blobs decorativos -->
                        <div class="absolute -top-12 -right-12 -z-10 h-64 w-64 rounded-full bg-primary/20 blur-3xl">
                        </div>
                        <div class="absolute -bottom-12 -left-12 -z-10 h-64 w-64 rounded-full bg-blue-500/10 blur-3xl">
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ─── ¿QUÉ ES? ──────────────────────────────────────────────────── -->
        <section class="bg-white py-16 lg:py-24">
            <div class="mx-auto max-w-4xl px-6 lg:px-8">
                <div class="text-center mb-12">
                    <span
                        class="inline-flex items-center gap-1.5 rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary mb-4"
                    >
                        <span class="material-symbols-outlined text-[14px]">info</span>
                        Definición legal
                    </span>
                    <h2 class="text-3xl font-black tracking-tight text-secondary sm:text-4xl">¿Qué es un pagaré?</h2>
                </div>

                <!-- Definición destacada -->
                <div class="rounded-lg border-l-4 border-primary bg-slate-50 p-6 mb-10">
                    <p class="text-base text-slate-700 leading-relaxed italic">
                        "El pagaré debe contener, además de los requisitos que establece el artículo 621: 1) La promesa
                        incondicional de pagar una suma determinada de dinero; 2) El nombre de la persona a quien deba
                        hacerse el pago; 3) La indicación de ser pagadero a la orden o al portador, y 4) La forma de
                        vencimiento."
                    </p>
                    <p class="mt-3 text-sm font-semibold text-primary">Código de Comercio colombiano, Art. 709</p>
                </div>

                <div class="prose prose-slate max-w-none text-slate-600 text-base leading-relaxed space-y-4">
                    <p>
                        En términos simples, un pagaré es un documento en el que una persona (el <strong>deudor</strong>
                        u otorgante) promete por escrito pagar una suma de dinero a otra (el <strong>acreedor</strong> o beneficiario)
                        en una fecha específica. Es un <strong>título valor</strong>, lo que significa que incorpora un
                        derecho de cobro ejecutable directamente ante un juez sin necesidad de probar la deuda.
                    </p>
                    <p>
                        A diferencia de un simple recibo, un contrato de préstamo o una promesa verbal, el pagaré
                        permite iniciar un <strong>proceso ejecutivo</strong> (artículo 430 del Código General del Proceso):
                        con solo presentarlo, el juez libra mandamiento de pago contra el deudor. Por eso se usa para garantizar
                        préstamos, créditos comerciales, obligaciones bancarias y acuerdos de pago.
                    </p>
                </div>

                <!-- Pills de tipo -->
                <div class="mt-10 flex flex-wrap gap-3 justify-center">
                    {
                        [
                            { icon: 'event_available', label: 'Pago único', detalle: 'Una sola fecha de vencimiento' },
                            {
                                icon: 'calendar_month',
                                label: 'Pago en cuotas',
                                detalle: 'Mensual, bimestral o trimestral',
                            },
                            { icon: 'edit_document', label: 'A la orden', detalle: 'Beneficiario específico' },
                        ].map((t) => (
                            <div class="flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-4 py-3 shadow-sm">
                                <span class="material-symbols-outlined text-primary text-[20px]">{t.icon}</span>
                                <div>
                                    <p class="text-sm font-bold text-secondary">{t.label}</p>
                                    <p class="text-xs text-slate-500">{t.detalle}</p>
                                </div>
                            </div>
                        ))
                    }
                </div>

                <!-- Pagaré en blanco -->
                <div class="mt-10 rounded-lg bg-amber-50 border border-amber-200 p-5 flex gap-4">
                    <span class="material-symbols-outlined text-amber-500 text-[24px] shrink-0 mt-0.5">warning</span>
                    <div>
                        <p class="text-sm font-bold text-amber-900 mb-1">Cuidado con el pagaré en blanco</p>
                        <p class="text-sm text-amber-800 leading-relaxed">
                            El artículo 622 del Código de Comercio permite firmarlo con espacios en blanco, pero
                            requiere que lo acompañes de una <strong>carta de instrucciones escrita</strong> que indique cómo
                            debe llenarse. Sin esa carta, el acreedor puede diligenciarlo con un monto o fecha que nunca acordaste.
                            Nunca firmes un pagaré en blanco sin instrucciones por escrito.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ─── ¿CUÁNDO NECESITAS UNO? ───────────────────────────────────── -->
        <section class="bg-neutral-50 py-16 lg:py-24">
            <div class="mx-auto max-w-5xl px-6 lg:px-8">
                <div class="text-center mb-12">
                    <h2 class="text-3xl font-black tracking-tight text-secondary sm:text-4xl">
                        ¿Cuándo necesitas un pagaré?
                    </h2>
                    <p class="mt-3 text-lg text-slate-600 max-w-xl mx-auto">
                        Siempre que quieras respaldar una obligación de pago en dinero con fuerza ejecutiva.
                    </p>
                </div>

                <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
                    {
                        [
                            {
                                icon: 'payments',
                                titulo: 'Prestar dinero a un tercero',
                                descripcion:
                                    'Si le prestas plata a un familiar, amigo o socio, el pagaré te permite exigir el pago por vía ejecutiva si no cumple, sin necesidad de probar la deuda en un proceso ordinario.',
                            },
                            {
                                icon: 'handshake',
                                titulo: 'Acuerdo de pago comercial',
                                descripcion:
                                    'Cuando un cliente reconoce una deuda y se compromete a pagarla en cuotas. El pagaré documenta el compromiso y te da título ejecutivo si incumple.',
                            },
                            {
                                icon: 'security',
                                titulo: 'Garantía de un negocio',
                                descripcion:
                                    'Como respaldo de un contrato de arrendamiento, compraventa a plazos o cualquier obligación futura. El pagaré refuerza la seguridad del acreedor.',
                            },
                        ].map((c) => (
                            <div class="rounded-lg border border-slate-200 bg-white p-7 shadow-sm">
                                <span class="mb-5 flex h-11 w-11 items-center justify-center rounded-full bg-primary/10">
                                    <span class="material-symbols-outlined text-[22px] text-primary">{c.icon}</span>
                                </span>
                                <h3 class="text-base font-black text-secondary mb-2">{c.titulo}</h3>
                                <p class="text-sm text-slate-600 leading-relaxed">{c.descripcion}</p>
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- ─── MARCO LEGAL ───────────────────────────────────────────────── -->
        <section class="bg-white py-16 lg:py-24">
            <div class="mx-auto max-w-4xl px-6 lg:px-8">
                <div class="text-center mb-12">
                    <span
                        class="inline-flex items-center gap-1.5 rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary mb-4"
                    >
                        <span class="material-symbols-outlined text-[14px]">balance</span>
                        Normatividad
                    </span>
                    <h2 class="text-3xl font-black tracking-tight text-secondary sm:text-4xl">
                        ¿Bajo qué normativa se rige?
                    </h2>
                    <p class="mt-3 text-lg text-slate-600 max-w-xl mx-auto">
                        El pagaré es un título valor regulado principalmente por el Código de Comercio de Colombia.
                    </p>
                </div>

                <div class="flex flex-col gap-6">
                    {
                        [
                            {
                                norma: 'Código de Comercio, Art. 621',
                                year: '1971',
                                color: 'bg-slate-100 border-slate-300',
                                textColor: 'text-slate-600',
                                titulo: 'Requisitos generales de los títulos valores',
                                descripcion:
                                    'Establece que todo título valor debe contener al menos dos elementos: la mención del derecho que se incorpora y la firma de quien lo crea. Sin firma, el pagaré no existe jurídicamente.',
                            },
                            {
                                norma: 'Código de Comercio, Art. 709',
                                year: '1971',
                                color: 'bg-primary/10 border-primary/30',
                                textColor: 'text-primary',
                                titulo: 'Requisitos específicos del pagaré',
                                descripcion:
                                    'Define los cuatro elementos propios del pagaré: promesa incondicional de pagar una suma determinada, nombre del beneficiario, indicación de ser pagadero a la orden o al portador, y forma de vencimiento. Si falta uno, pierde su carácter de título valor.',
                            },
                            {
                                norma: 'Código de Comercio, Art. 789',
                                year: '1971',
                                color: 'bg-blue-50 border-blue-200',
                                textColor: 'text-blue-700',
                                titulo: 'Prescripción de la acción cambiaria directa',
                                descripcion:
                                    'La acción cambiaria directa contra el deudor principal prescribe en tres (3) años contados desde la fecha de vencimiento. Pasado ese plazo, el pagaré pierde fuerza ejecutiva aunque la obligación natural subsista.',
                            },
                            {
                                norma: 'Código de Comercio, Art. 884',
                                year: '1971',
                                color: 'bg-amber-50 border-amber-200',
                                textColor: 'text-amber-700',
                                titulo: 'Límite de intereses y sanción por usura',
                                descripcion:
                                    'Fija el límite de los intereses remuneratorios y moratorios. Si se pactan tasas por encima del máximo legal certificado por la Superintendencia Financiera (24,36% E.A. para enero de 2026), el acreedor pierde todos los intereses.',
                            },
                        ].map((n) => (
                            <div class={`rounded-lg border ${n.color} p-6 flex gap-5`}>
                                <div class="shrink-0 text-center">
                                    <span class={`text-xs font-black uppercase tracking-wider ${n.textColor}`}>
                                        {n.year}
                                    </span>
                                </div>
                                <div>
                                    <p class={`text-xs font-bold uppercase tracking-wider ${n.textColor} mb-1`}>
                                        {n.norma}
                                    </p>
                                    <h3 class="text-base font-black text-secondary mb-1">{n.titulo}</h3>
                                    <p class="text-sm text-slate-600 leading-relaxed">{n.descripcion}</p>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- ─── PARTES DEL PAGARÉ ─────────────────────────────────────────── -->
        <section class="bg-neutral-50 py-16 lg:py-24">
            <div class="mx-auto max-w-5xl px-6 lg:px-8">
