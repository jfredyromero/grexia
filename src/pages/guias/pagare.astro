                                <p class="text-xs text-primary font-semibold uppercase tracking-wide mt-0.5 mb-4">
                                    {p.rol}
                                </p>
                                <ul class="space-y-2">
                                    {p.obligaciones.map((o) => (
                                        <li class="flex items-start gap-2 text-sm text-slate-600">
                                            <span class="material-symbols-outlined text-primary text-[16px] mt-0.5 shrink-0">
                                                check_circle
                                            </span>
                                            {o}
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- ─── LOS PELIGROS ─────────────────────────────────────────────── -->
        <section class="bg-secondary py-16 lg:py-24">
            <div class="mx-auto max-w-5xl px-6 lg:px-8">
                <div class="text-center mb-12">
                    <span
