                                titulo: 'Acreedor',
                                rol: 'Beneficiario del pago',
                                obligaciones: [
                                    'Recibir el pago en la fecha pactada',
                                    'Diligenciar el pagaré conforme a instrucciones si lo recibió en blanco',
                                    'Entregar o destruir el pagaré una vez pagado',
                                    'Iniciar el proceso ejecutivo dentro de los 3 años si incumple el deudor',
                                ],
                            },
                            {
                                icon: 'person_outline',
                                titulo: 'Deudor',
                                rol: 'Otorgante del pagaré',
                                obligaciones: [
                                    'Pagar la suma prometida en la fecha acordada',
                                    'Pagar los intereses remuneratorios y moratorios pactados',
                                    'Responder con todo su patrimonio ante incumplimiento',
                                    'Conservar copia del pagaré y de la carta de instrucciones',
                                ],
                            },
                        ].map((p) => (
                            <div class="rounded-lg border border-slate-200 bg-white p-7 shadow-sm">
                                <span class="mb-4 flex h-11 w-11 items-center justify-center rounded-full bg-primary/10">
