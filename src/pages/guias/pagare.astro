                            el PDF.
                        </p>
                    </div>
                    <a
                        href={base + tool.href.landing}
                        class="shrink-0 flex h-11 items-center justify-center gap-1.5 rounded-full bg-primary px-6 text-sm font-bold text-white shadow-sm hover:bg-primary-hover transition-colors"
                    >
                        Ver herramienta
                        <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                    </a>
                </div>
            </div>
        </section>

        <!-- ─── ¿CUÁNDO NECESITAS UN ABOGADO? ───────────────────────────── -->
