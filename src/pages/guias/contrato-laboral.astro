---
import Layout from '../../layouts/Layout.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import Breadcrumb from '../../components/shared/Breadcrumb.astro';
import FAQAccordion from '../../components/shared/FAQAccordion.tsx';
import { TOOLS } from '../../config/tools';

const base = import.meta.env.BASE_URL;
const tool = TOOLS.find((t) => t.slug === 'laboral')!;

const trustBadges = [
    { icon: 'balance', label: 'Marco legal vigente' },
    { icon: 'lock', label: 'Sin registro' },
    { icon: 'picture_as_pdf', label: 'PDF en 1 minuto' },
];

const socialAvatars = [
    {
        src: 'https://lh3.googleusercontent.com/aida-public/AB6AXuD5V-on_7keAJEftPazMB7vJ67iatf4qd4WOg_ZLAGyQBUYYmpcgWK5CelWduBdraqtPEVMpbZacLQTptHErkMPUSMqVXJe326yqQ1W5TwXEGPS4jEK_qNcJlia7lnzWXHb8dHj4yFQ0yb8dgypVkMEydK7l4KuqFSfMe08sorNHA100WBaGKGVLRDnkqDwuhJaz29ykI2nxkBUGnMcdVoXgJQJLSjQy3dkBNGn3kCa3dXugbVN6ZcyTay7ASuwwRvKF5m__5lVmKDy',
        alt: 'Usuaria de Grexia',
    },
    {
        src: 'https://lh3.googleusercontent.com/aida-public/AB6AXuCfp-jh4m6Wbqi9eNLW5obsxwye-auLWzPod3k8AJEROlnlaC_1aesC1FHe7w3PXdQekpmc1AW1_i3T5me0j8M5OUwqa88kbLcNPK3-4JyenI6zUb4QR6Av2Yh4wh10lu4brK_rCWq_2EIcu93vRZ4rWuRPfxhmVwSAVnZVNXWprqEEhh8Pv6fQZO5Hir-sQmpAv-PUqk9Lx0iPvBHpG-Ufxf9VoI2PTL81xeLGJ_9uZ5UabQYR-HFeNlBSdNJxQeWQyU2Tj0VbSAw9',
        alt: 'Usuario de Grexia',
    },
    {
        src: 'https://lh3.googleusercontent.com/aida-public/AB6AXuDCX5Y3IuUrv_PQkgw7I4x0hIq5GvqM4mNZH8Nf77tl1GcPXLaCsLSP2o-hJE_jkQBylIIrWbA_Agy1XvGpz_f8DUANpGrude4HanBLTVn0rjk9MH1DWXBs_2XcoV0BjA2Jv0TSycQXYoMDCFQ6jRTvQ7EqpI_UR5w-Hc1GzrtD-_-1gqsnysbzsx96QlqhDIlsLbggTZolxZyvIOnJ4GSC_Nr2qTSas446QFjH9RInxio5Jobdsm1Lu_97Tf-dswOGBLAidqyvqKbw',
        alt: 'Usuario de Grexia',
    },
];

const faqLaboral = [
    {
        question: '¿El contrato laboral debe ser por escrito o puede ser verbal?',
        answer: 'Depende del tipo de contrato. El contrato a término fijo y el contrato por obra o labor determinada deben celebrarse obligatoriamente por escrito (Art. 46 y 47 del Código Sustantivo del Trabajo). Si pactas un término fijo de manera verbal, la ley lo presume contrato a término indefinido. El contrato verbal es válido pero el empleador pierde toda la prueba de las condiciones pactadas y queda en desventaja en cualquier disputa.',
    },
    {
        question: '¿Cuál es el salario mínimo en Colombia para 2026?',
        answer: 'El salario mínimo legal mensual vigente (SMLMV) para 2026 es de $1.750.905, fijado por los decretos 1469 y 1470 del 29 de diciembre de 2025. A esto se suma el auxilio de transporte de $249.095 para trabajadores que ganen hasta dos salarios mínimos, lo que da un ingreso total de $2.000.000. Ningún contrato laboral puede pactar una remuneración inferior al SMLMV por jornada completa.',
    },
    {
        question: '¿Cuánto puede durar el período de prueba?',
        answer: 'El período de prueba no puede superar dos (2) meses según el artículo 78 del CST. En contratos a término fijo inferiores a un año, el período de prueba no puede exceder la quinta parte del término pactado, sin pasar de dos meses. Debe constar siempre por escrito. Si se celebran contratos sucesivos entre el mismo empleador y trabajador, solo es válido pactar período de prueba en el primero.',
    },
    {
        question: '¿Qué prestaciones sociales debe pagar el empleador?',
        answer: 'Todo trabajador con contrato laboral, sin importar el tipo, tiene derecho a: cesantías (8,33% del salario mensual, equivalente a un mes de salario por año), intereses sobre las cesantías (12% anual sobre las cesantías causadas), prima de servicios (8,33%, pagada en junio y diciembre) y vacaciones (15 días hábiles por año, equivalente al 4,17% del salario). Estas prestaciones son irrenunciables y obligatorias, incluso para contratos de un solo mes.',
    },
    {
        question: '¿Qué pasa si despido a un trabajador sin justa causa?',
        answer: 'El artículo 64 del CST obliga al empleador a pagar una indemnización. En contrato a término fijo, equivale al salario que falta para terminar el contrato. En contrato por obra o labor, equivale al salario por el tiempo restante de la obra, con un mínimo de 15 días. En contrato a término indefinido, depende del salario y los años de servicio (20 días por el primer año más 15 días por cada año adicional para salarios inferiores a 10 SMLMV).',
    },
    {
        question: '¿Cuántas veces puedo renovar un contrato a término fijo?',
        answer: 'El contrato a término fijo no puede pactarse por más de 4 años. Si ninguna de las partes avisa por escrito la decisión de no prorrogarlo con al menos 30 días de antelación al vencimiento, se entiende renovado por un período igual al inicialmente pactado. Si el término inicial es inferior a un año, solo puede renovarse hasta tres veces por períodos iguales o inferiores; a partir de la cuarta renovación, el plazo no puede ser inferior a un año.',
    },
];

const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqLaboral.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: { '@type': 'Answer', text: faq.answer },
    })),
};
---

<Layout
    title="Contrato Laboral en Colombia: Guía Completa | Grexia"
    description="Aprende qué es un contrato laboral, los tipos en Colombia, las prestaciones sociales obligatorias y los riesgos de no tenerlo por escrito. Genera el tuyo gratis en Grexia."
    canonical="https://grexia.co/guias/contrato-laboral"
    schema={faqSchema}
>
    <main class="grow w-full">
        <!-- ─── HERO ──────────────────────────────────────────────────────── -->
        <section class="grow flex items-center justify-center">
            <div class="relative w-full max-w-7xl px-6 lg:px-8 py-8 lg:py-14">
                <!-- Breadcrumb -->
                <div class="mb-10">
                    <Breadcrumb items={[{ label: 'Guías', href: base + 'guias' }, { label: 'Contrato Laboral' }]} />
                </div>

                <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-20 items-center">
                    <!-- Izquierda: texto -->
                    <div class="flex flex-col gap-8 order-2 lg:order-1">
                        <!-- Trust Badges -->
                        <div class="hidden lg:flex flex-wrap gap-3">
                            {
                                trustBadges.map((badge) => (
                                    <div class="flex items-center gap-1.5 rounded-full bg-white border border-slate-200 px-3 py-1.5 shadow-sm">
                                        <span class="material-symbols-outlined text-primary text-[20px] font-bold">
                                            {badge.icon}
                                        </span>
                                        <span class="text-xs font-semibold text-slate-700 uppercase tracking-wide">
                                            {badge.label}
                                        </span>
                                    </div>
                                ))
                            }
                        </div>

                        <!-- H1 -->
                        <div class="space-y-6">
                            <h1
                                class="text-4xl font-black leading-[1.1] tracking-tight text-secondary sm:text-5xl xl:text-6xl"
                            >
                                Todo sobre el contrato
                                <span class="relative whitespace-nowrap text-secondary">
                                    laboral
                                    <span class="absolute bottom-1 left-0 -z-10 h-3 w-full bg-primary/40 rounded-full"
                                    ></span>
                                </span>
                                en Colombia
                            </h1>
                            <p class="max-w-lg text-lg text-slate-600 leading-relaxed">
                                Entiende qué es, qué tipos existen, qué dice el Código Sustantivo del Trabajo y por qué
                                contratar sin documento escrito puede costarte millones en demandas laborales. Y al
                                final, genera el tuyo gratis en minutos.
                            </p>
                        </div>

                        <!-- CTAs -->
                        <div class="flex flex-col sm:flex-row gap-4 pt-2">
                            <a
                                href={base + tool.href.form}
                                class="flex h-14 items-center justify-center gap-2 rounded-full bg-primary px-8 text-base font-bold text-white shadow-md shadow-primary/20 transition-all hover:-translate-y-0.5 hover:bg-primary-hover hover:shadow-lg active:translate-y-0"
                            >
                                Generar contrato gratis
                                <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
                            </a>
                            <a
                                href={base + 'asesoria/checkout'}
                                class="flex h-14 items-center justify-center rounded-full bg-white border border-slate-200 px-8 text-base font-bold text-slate-700 shadow-sm transition-all hover:bg-slate-50 hover:border-slate-300"
                            >
                                Hablar con un abogado
                            </a>
                        </div>

                        <!-- Social Proof -->
                        <div class="flex items-center gap-4 pt-6 border-t border-slate-200 mt-2">
                            <div class="flex -space-x-4">
                                {
                                    socialAvatars.map((a) => (
                                        <img
                                            alt={a.alt}
                                            class="h-12 w-12 rounded-full border-2 border-white object-cover"
                                            src={a.src}
                                        />
                                    ))
                                }
                                <div
                                    class="flex h-12 w-12 items-center justify-center rounded-full border-2 border-white bg-secondary text-xs font-bold text-white"
                                >
                                    +1.2k
                                </div>
                            </div>
                            <div class="flex flex-col justify-center">
                                <div class="flex text-yellow-400 text-sm">
                                    {
                                        Array.from({ length: 5 }).map(() => (
                                            <span class="material-symbols-outlined text-[18px]">star</span>
                                        ))
                                    }
                                </div>
                                <p class="text-sm font-medium text-slate-600">
                                    Más de <span class="font-bold text-secondary">3.200 documentos</span> generados
                                </p>
                            </div>
                        </div>

                        <!-- Legal basis -->
                        <p class="text-sm text-slate-500 -mt-4">
                            Conforme al <strong class="text-slate-700"
                                >Código Sustantivo del Trabajo (Decreto 2663 de 1950) y la Ley 50 de 1990</strong
                            >
                        </p>
                    </div>

                    <!-- Derecha: imagen -->
                    <div class="relative hidden lg:block order-1 lg:order-2">
                        <div
                            class="relative w-full aspect-4/5 md:aspect-square lg:aspect-4/5 overflow-hidden rounded-[2.5rem] bg-slate-100 shadow-2xl"
                        >
                            <img
                                alt="Contrato laboral en Colombia"
                                class="h-full w-full object-cover object-center"
                                src={tool.heroImage}
                            />
                            <div class="absolute inset-0 bg-linear-to-t from-secondary/20 to-transparent"></div>

                            <!-- Glass Widget: abogado -->
                            <div
                                class="glass-widget absolute top-8 right-6 flex max-w-65 flex-col gap-3 rounded-lg p-4 animate-[fade-in-up_1s_ease-out_0.5s_backwards]"
                            >
                                <div class="flex items-center gap-3">
                                    <div class="relative">
                                        <img
                                            alt={tool.heroLawyerName}
                                            class="h-10 w-10 rounded-full bg-primary border border-white object-cover"
                                            src={tool.heroLawyerAvatar}
                                        />
                                        <div
                                            class="absolute bottom-0 right-0 h-3 w-3 rounded-full bg-green-500 border-2 border-white"
                                        >
                                        </div>
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="text-sm font-bold text-slate-800">{tool.heroLawyerName}</span>
                                        <span class="text-xs text-slate-700">{tool.heroLawyerSpecialty}</span>
                                    </div>
                                </div>
                                <div
                                    class="rounded-xl bg-white/60 p-2 text-xs text-slate-700 leading-snug backdrop-blur-sm"
                                >
                                    "{tool.heroChat}"
                                </div>
                            </div>

                            <!-- Glass Widget: guía badge -->
                            <div
                                class="glass-widget absolute bottom-8 left-6 flex items-center gap-3 rounded-full py-3 px-5 pr-8"
                            >
                                <div
                                    class="flex h-10 w-10 items-center justify-center rounded-full bg-primary text-white"
                                >
                                    <span class="material-symbols-outlined text-[24px]">menu_book</span>
                                </div>
                                <div>
                                    <p class="text-xs text-slate-700 font-medium uppercase tracking-wider">
                                        Guía completa
                                    </p>
                                    <p class="text-sm font-bold text-slate-800">Normativa vigente</p>
                                </div>
                            </div>
                        </div>

                        <!-- Blobs decorativos -->
                        <div class="absolute -top-12 -right-12 -z-10 h-64 w-64 rounded-full bg-primary/20 blur-3xl">
                        </div>
                        <div class="absolute -bottom-12 -left-12 -z-10 h-64 w-64 rounded-full bg-blue-500/10 blur-3xl">
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ─── ¿QUÉ ES? ──────────────────────────────────────────────────── -->
        <section class="bg-white py-16 lg:py-24">
            <div class="mx-auto max-w-4xl px-6 lg:px-8">
                <div class="text-center mb-12">
                    <span
                        class="inline-flex items-center gap-1.5 rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary mb-4"
                    >
                        <span class="material-symbols-outlined text-[14px]">info</span>
                        Definición legal
                    </span>
                    <h2 class="text-3xl font-black tracking-tight text-secondary sm:text-4xl">
                        ¿Qué es un contrato laboral?
                    </h2>
                </div>

                <!-- Definición destacada -->
                <div class="rounded-lg border-l-4 border-primary bg-slate-50 p-6 mb-10">
                    <p class="text-base text-slate-700 leading-relaxed italic">
                        "Contrato de trabajo es aquel por el cual una persona natural se obliga a prestar un servicio
                        personal a otra persona, natural o jurídica, bajo la continuada dependencia o subordinación de
                        la segunda y mediante remuneración."
                    </p>
                    <p class="mt-3 text-sm font-semibold text-primary">Código Sustantivo del Trabajo, Art. 22</p>
                </div>

                <div class="prose prose-slate max-w-none text-slate-600 text-base leading-relaxed space-y-4">
                    <p>
                        En términos simples, un contrato laboral es el acuerdo formal entre quien contrata (<strong
                            >empleador</strong
                        >) y quien presta el servicio personal (<strong>trabajador</strong>). Define el cargo, el
                        salario, la jornada, la duración y todas las condiciones bajo las cuales se desarrollará la
                        relación laboral en Colombia.
                    </p>
                    <p>
                        Para que exista un contrato de trabajo, el artículo 23 del CST exige tres elementos esenciales: <strong
                            >actividad personal</strong
                        > del trabajador, <strong>subordinación</strong> continua respecto del empleador y <strong
                            >salario</strong
                        > como retribución. Si estos tres elementos están presentes, hay contrato laboral, sin importar el
                        nombre que se le dé al documento.
                    </p>
                </div>

                <!-- Pills de tipo -->
                <div class="mt-10 flex flex-wrap gap-3 justify-center">
                    {
                        [
                            { icon: 'event', label: 'Término fijo', ley: 'Art. 46 CST' },
                            { icon: 'construction', label: 'Obra o labor', ley: 'Art. 45 CST' },
                            { icon: 'all_inclusive', label: 'Término indefinido', ley: 'Art. 47 CST' },
                        ].map((t) => (
                            <div class="flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-4 py-3 shadow-sm">
                                <span class="material-symbols-outlined text-primary text-[20px]">{t.icon}</span>
                                <div>
                                    <p class="text-sm font-bold text-secondary">{t.label}</p>
                                    <p class="text-xs text-slate-500">{t.ley}</p>
                                </div>
                            </div>
                        ))
                    }
                </div>

                <!-- Verbal vs escrito -->
                <div class="mt-10 rounded-lg bg-amber-50 border border-amber-200 p-5 flex gap-4">
                    <span class="material-symbols-outlined text-amber-500 text-[24px] shrink-0 mt-0.5">warning</span>
                    <div>
                        <p class="text-sm font-bold text-amber-900 mb-1">¿Verbal o escrito?</p>
                        <p class="text-sm text-amber-800 leading-relaxed">
                            El contrato a término fijo y el contrato por obra o labor deben celebrarse obligatoriamente
                            por escrito (Art. 46 y 47 del CST). Si pactas un término fijo de manera verbal, la ley lo
                            presume contrato a término indefinido. <strong
                                >Sin documento escrito, el empleador pierde toda prueba de las condiciones pactadas.</strong
                            >
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ─── ¿CUÁNDO NECESITAS UNO? ───────────────────────────────────── -->
        <section class="bg-neutral-50 py-16 lg:py-24">
            <div class="mx-auto max-w-5xl px-6 lg:px-8">
                <div class="text-center mb-12">
                    <h2 class="text-3xl font-black tracking-tight text-secondary sm:text-4xl">
                        ¿Cuándo necesitas un contrato laboral?
                    </h2>
                    <p class="mt-3 text-lg text-slate-600 max-w-xl mx-auto">
                        Siempre que contrates a alguien bajo tu dirección y pago de salario, lo necesitas por escrito.
                    </p>
                </div>

                <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
                    {
                        [
                            {
                                icon: 'event',
                                titulo: 'Contratación a plazo definido',
                                descripcion:
                                    'Cuando contratas a un trabajador para una posición estable por un período de hasta 4 años (puede renovarse). Ideal para proyectos con fecha de cierre o validar la posición.',
                            },
                            {
                                icon: 'construction',
                                titulo: 'Obra o labor determinada',
                                descripcion:
                                    'Cuando contratas para ejecutar una obra específica con principio y fin claros: una construcción, una campaña, un proyecto técnico. La duración la marca la obra, no el calendario.',
                            },
                            {
                                icon: 'business_center',
                                titulo: 'Formalizar relación existente',
                                descripcion:
                                    'Si ya tienes una persona trabajando contigo bajo subordinación y pago de salario, ya hay contrato laboral aunque no esté firmado. Formalizarlo te protege ante demandas y la UGPP.',
                            },
                        ].map((c) => (
                            <div class="rounded-lg border border-slate-200 bg-white p-7 shadow-sm">
                                <span class="mb-5 flex h-11 w-11 items-center justify-center rounded-full bg-primary/10">
                                    <span class="material-symbols-outlined text-[22px] text-primary">{c.icon}</span>
                                </span>
                                <h3 class="text-base font-black text-secondary mb-2">{c.titulo}</h3>
                                <p class="text-sm text-slate-600 leading-relaxed">{c.descripcion}</p>
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- ─── MARCO LEGAL ───────────────────────────────────────────────── -->
        <section class="bg-white py-16 lg:py-24">
            <div class="mx-auto max-w-4xl px-6 lg:px-8">
                <div class="text-center mb-12">
                    <span
                        class="inline-flex items-center gap-1.5 rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary mb-4"
                    >
                        <span class="material-symbols-outlined text-[14px]">balance</span>
                        Normatividad
                    </span>
                    <h2 class="text-3xl font-black tracking-tight text-secondary sm:text-4xl">
                        ¿Bajo qué normativa se rige?
                    </h2>
                    <p class="mt-3 text-lg text-slate-600 max-w-xl mx-auto">
                        El contrato laboral en Colombia se rige por una norma central y sus reformas vigentes.
                    </p>
                </div>

                <div class="flex flex-col gap-6">
                    {
                        [
                            {
                                norma: 'Decreto 2663 de 1950',
                                year: '1950',
                                color: 'bg-slate-100 border-slate-300',
                                textColor: 'text-slate-600',
                                titulo: 'Código Sustantivo del Trabajo',
                                descripcion:
                                    'La norma raíz que regula todas las relaciones laborales en Colombia. Define qué es un contrato de trabajo (Art. 22), sus elementos esenciales (Art. 23), los tipos de contrato (Art. 45) y las obligaciones de las partes.',
                            },
                            {
                                norma: 'Ley 50 de 1990',
                                year: '1990',
                                color: 'bg-primary/10 border-primary/30',
                                textColor: 'text-primary',
                                titulo: 'Reforma Laboral',
                                descripcion:
                                    'Modificó el régimen de cesantías al sistema anual de consignación, ajustó las reglas del contrato a término fijo (máximo 4 años, renovaciones automáticas con preaviso de 30 días) y actualizó las indemnizaciones por despido sin justa causa.',
                            },
                            {
                                norma: 'Ley 789 de 2002',
                                year: '2002',
                                color: 'bg-blue-50 border-blue-200',
                                textColor: 'text-blue-700',
                                titulo: 'Reforma del régimen de protección social',
                                descripcion:
                                    'Ajustó la jornada laboral nocturna, los recargos por trabajo dominical y festivo, y los topes para indemnizaciones por despido. Sigue siendo la base para calcular los recargos salariales y la duración legal de la jornada.',
                            },
                        ].map((n) => (
                            <div class={`rounded-lg border ${n.color} p-6 flex gap-5`}>
                                <div class="shrink-0 text-center">
                                    <span class={`text-xs font-black uppercase tracking-wider ${n.textColor}`}>
                                        {n.year}
                                    </span>
                                </div>
                                <div>
                                    <p class={`text-xs font-bold uppercase tracking-wider ${n.textColor} mb-1`}>
                                        {n.norma}
                                    </p>
                                    <h3 class="text-base font-black text-secondary mb-1">{n.titulo}</h3>
                                    <p class="text-sm text-slate-600 leading-relaxed">{n.descripcion}</p>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- ─── PARTES DEL CONTRATO ───────────────────────────────────────── -->
        <section class="bg-neutral-50 py-16 lg:py-24">
            <div class="mx-auto max-w-5xl px-6 lg:px-8">
                <div class="text-center mb-12">
                    <h2 class="text-3xl font-black tracking-tight text-secondary sm:text-4xl">
                        ¿Quiénes participan en el contrato?
                    </h2>
                    <p class="mt-3 text-lg text-slate-600 max-w-xl mx-auto">
                        Cada parte tiene derechos y obligaciones específicas definidas en los artículos 57 y 58 del CST.
                    </p>
                </div>

                <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
                    {
                        [
                            {
                                icon: 'business',
                                titulo: 'Empleador',
                                rol: 'Persona natural o jurídica que contrata',
                                obligaciones: [
                                    'Pagar la remuneración pactada en las fechas y lugares convenidos',
                                    'Suministrar los instrumentos y elementos de trabajo necesarios',
                                    'Garantizar condiciones de seguridad y salud en el trabajo',
                                    'Pagar prestaciones sociales y aportes a seguridad social',
                                ],
                            },
                            {
                                icon: 'badge',
                                titulo: 'Trabajador',
                                rol: 'Persona natural que presta el servicio personal',
                                obligaciones: [
                                    'Realizar personalmente la labor en los términos pactados',
