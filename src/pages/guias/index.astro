---
import Layout from '../../layouts/Layout.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';

const base = import.meta.env.BASE_URL;

const guias = [
    {
        href: base + 'guias/contrato-arrendamiento',
        icon: 'home_work',
        titulo: 'Contrato de Arrendamiento',
        descripcion:
            'Aprende qué dice la Ley 820 sobre vivienda urbana, canon, depósitos y terminación antes de firmar con tu arrendador.',
        marco: 'Ley 820 de 2003',
        herramienta: 'arrendamiento',
    },
    {
        href: base + 'guias/pagare',
        icon: 'request_quote',
        titulo: 'Pagaré',
        descripcion:
            'Entiende por qué el pagaré es un título valor y qué requisitos del Código de Comercio lo hacen ejecutable ante un juez.',
        marco: 'Código de Comercio',
        herramienta: 'pagare',
    },
    {
        href: base + 'guias/promesa-compraventa',
        icon: 'handshake',
        titulo: 'Promesa de Compraventa',
        descripcion:
            'Qué exige el artículo 1611 del Código Civil, por qué una promesa mal hecha es nula y cómo proteger tus arras.',
        marco: 'Código Civil Art. 1611',
        herramienta: 'compraventa',
    },
    {
        href: base + 'guias/contrato-laboral',
        icon: 'work',
        titulo: 'Contrato Laboral',
        descripcion:
            'Tipos de contrato, prestaciones sociales obligatorias, período de prueba y por qué contratar verbalmente puede costarte millones.',
        marco: 'Código Sustantivo del Trabajo',
        herramienta: 'laboral',
    },
    {
        href: base + 'guias/liquidacion-de-intereses',
        icon: 'calculate',
        titulo: 'Liquidación de Intereses',
        descripcion:
            'Cómo calcular intereses corrientes y moratorios con tasas Superfinanciera. Tasa de usura, anatocismo y Art. 884 del Código de Comercio.',
        marco: 'Código de Comercio Art. 884',
        herramienta: 'intereses',
    },
    {
        href: base + 'guias/accion-de-tutela',
        icon: 'gavel',
        titulo: 'Acción de Tutela',
        descripcion:
            'Cómo proteger tus derechos fundamentales en 10 días. Tutela contra EPS por medicamentos, procedimientos y demoras según el Art. 86 de la Constitución.',
        marco: 'Art. 86 Constitución Política',
        herramienta: 'tutela',
    },
];
---

<Layout
    title="Guías legales de Grexia | Contratos y Pagarés Colombia"
    description="Guías educativas sobre contratos de arrendamiento, pagarés y promesas de compraventa en Colombia. Entiende la ley antes de firmar y genera tus documentos."
    canonical="https://grexia.co/guias"
>
    <main class="grow w-full">
        {/* ── Hero ── */}
        <section class="bg-white pt-14 pb-0 lg:pt-20">
            <div class="mx-auto max-w-4xl px-6 lg:px-8 text-center">
                <h1 class="text-4xl font-black tracking-tight text-secondary sm:text-5xl lg:text-6xl leading-tight">
                    Antes de firmar, entiende qué estás
                    <span class="relative inline-block">
                        <span class="relative z-10">firmando</span>
                        <span
                            aria-hidden="true"
                            class="absolute left-0 bottom-1 h-3 w-full rounded-full bg-primary/20"
                        ></span>
                    </span>
                </h1>
                <p class="mx-auto mt-8 max-w-xl text-lg text-slate-600">
                    Estas guías te explican, sin tecnicismos, qué dice la ley colombiana sobre los documentos más
                    usados. Antes de firmar o cobrar, asegúrate de entender lo que te obliga.
                </p>
            </div>
        </section>

        {/* ── Guides Grid ── */}
        <section class="bg-white py-16 lg:py-24">
            <div class="mx-auto max-w-5xl px-6 lg:px-8">
                <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                    {
                        guias.map((guia) => (
                            <a
                                href={guia.href}
                                class="group flex flex-col rounded-lg border border-slate-200 bg-white p-8 shadow-sm transition-all hover:shadow-md hover:-translate-y-0.5"
                            >
                                <div class="mb-5 flex h-11 w-11 items-center justify-center rounded-full bg-primary/10">
                                    <span class="material-symbols-outlined text-[22px] text-primary">{guia.icon}</span>
                                </div>

                                <h2 class="text-lg font-black text-secondary leading-snug">{guia.titulo}</h2>
                                <p class="mt-2 text-sm text-slate-600 leading-relaxed line-clamp-2">
                                    {guia.descripcion}
                                </p>

                                <div class="mt-5 flex flex-wrap gap-2">
                                    <span class="inline-flex items-center gap-1 rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary">
                                        <span class="material-symbols-outlined text-[14px]">balance</span>
                                        {guia.marco}
                                    </span>
                                    <span class="inline-flex items-center gap-1 rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700">
                                        <span class="material-symbols-outlined text-[14px]">check_circle</span>
                                        Herramienta disponible
                                    </span>
                                </div>

                                <div class="mt-auto pt-6 flex items-center gap-1 text-sm font-bold text-primary">
                                    Ver guía
                                    <span class="material-symbols-outlined text-[16px] transition-transform group-hover:translate-x-0.5">
                                        arrow_forward
                                    </span>
                                </div>
                            </a>
                        ))
                    }
                </div>
            </div>
        </section>
    </main>
    <WhatsAppButton />
</Layout>
