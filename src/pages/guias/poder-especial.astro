---
import Layout from '../../layouts/Layout.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import Breadcrumb from '../../components/shared/Breadcrumb.astro';
import FAQAccordion from '../../components/shared/FAQAccordion.tsx';
import { TOOLS } from '../../config/tools';

const base = import.meta.env.BASE_URL;
const tool = TOOLS.find((t) => t.slug === 'poder-especial')!;

const trustBadges = [
    { icon: 'balance', label: 'Marco legal vigente' },
    { icon: 'lock', label: 'Sin registro' },
    { icon: 'picture_as_pdf', label: 'PDF en 1 minuto' },
];

const socialAvatars = [
    {
        src: 'https://lh3.googleusercontent.com/aida-public/AB6AXuD5V-on_7keAJEftPazMB7vJ67iatf4qd4WOg_ZLAGyQBUYYmpcgWK5CelWduBdraqtPEVMpbZacLQTptHErkMPUSMqVXJe326yqQ1W5TwXEGPS4jEK_qNcJlia7lnzWXHb8dHj4yFQ0yb8dgypVkMEydK7l4KuqFSfMe08sorNHA100WBaGKGVLRDnkqDwuhJaz29ykI2nxkBUGnMcdVoXgJQJLSjQy3dkBNGn3kCa3dXugbVN6ZcyTay7ASuwwRvKF5m__5lVmKDy',
        alt: 'Usuaria de Grexia',
    },
    {
        src: 'https://lh3.googleusercontent.com/aida-public/AB6AXuCfp-jh4m6Wbqi9eNLW5obsxwye-auLWzPod3k8AJEROlnlaC_1aesC1FHe7w3PXdQekpmc1AW1_i3T5me0j8M5OUwqa88kbLcNPK3-4JyenI6zUb4QR6Av2Yh4wh10lu4brK_rCWq_2EIcu93vRZ4rWuRPfxhmVwSAVnZVNXWprqEEhh8Pv6fQZO5Hir-sQmpAv-PUqk9Lx0iPvBHpG-Ufxf9VoI2PTL81xeLGJ_9uZ5UabQYR-HFeNlBSdNJxQeWQyU2Tj0VbSAw9',
        alt: 'Usuario de Grexia',
    },
    {
        src: 'https://lh3.googleusercontent.com/aida-public/AB6AXuDCX5Y3IuUrv_PQkgw7I4x0hIq5GvqM4mNZH8Nf77tl1GcPXLaCsLSP2o-hJE_jkQBylIIrWbA_Agy1XvGpz_f8DUANpGrude4HanBLTVn0rjk9MH1DWXBs_2XcoV0BjA2Jv0TSycQXYoMDCFQ6jRTvQ7EqpI_UR5w-Hc1GzrtD-_-1gqsnysbzsx96QlqhDIlsLbggTZolxZyvIOnJ4GSC_Nr2qTSas446QFjH9RInxio5Jobdsm1Lu_97Tf-dswOGBLAidqyvqKbw',
        alt: 'Usuario de Grexia',
    },
];

const faqPoder = [
    {
        question: '¿Cuál es la diferencia entre un poder especial y un poder general?',
        answer: 'El artículo 2156 del Código Civil colombiano lo define con claridad: el poder especial se otorga para uno o varios negocios concretos y plenamente identificados (por ejemplo, un proceso de declaración de pertenencia o un trámite notarial específico), mientras que el poder general cubre todos los negocios del mandante. Para procesos judiciales, el Código General del Proceso (Art. 74) exige que el poder sea especial: los asuntos deben quedar determinados y claramente identificados, de lo contrario el juez puede inadmitir la demanda.',
    },
    {
        question: '¿Tengo que ir a la notaría para que el poder sea válido?',
        answer: 'Hoy ya no es obligatorio en la mayoría de los casos. La Ley 2213 de 2022 (que volvió permanente el Decreto 806 de 2020) permite que el poder especial para fines judiciales se otorgue por mensaje de datos con simple firma, sin presentación personal ni autenticación notarial. El poder se presume auténtico siempre que indique de manera expresa el correo electrónico del abogado, registrado en el Registro Nacional de Abogados. Para trámites notariales sí puede requerirse presentación personal según el acto.',
    },
    {
        question: '¿Qué pasa si el poder especial no identifica con claridad el proceso?',
        answer: 'El artículo 74 del Código General del Proceso exige que en los poderes especiales los asuntos estén "determinados y claramente identificados". Si el poder describe el proceso de forma vaga, omite el inmueble (cuando aplica) o no menciona a los demandados, el juez puede inadmitir la demanda y dar tres días para corregir. Si no se subsana, la demanda se rechaza y se pierde tiempo, dinero y, en ocasiones, derechos por prescripción. Por eso Grexia genera el poder con la información completa según el tipo de proceso que elijas.',
    },
    {
        question: '¿Puedo otorgarle el poder a alguien que no sea abogado?',
        answer: 'Para procesos judiciales no, salvo excepciones puntuales (por ejemplo, agencia oficiosa o representación legal de menores). El Decreto 196 de 1971 establece que solo los abogados con tarjeta profesional vigente pueden ejercer la profesión y representar a otros en procesos. Para trámites notariales y administración de bienes sí puedes otorgar el poder a una persona de confianza que no sea abogado, siempre que el poder describa con precisión las facultades que le concedes.',
    },
    {
        question: '¿Puedo revocar el poder en cualquier momento?',
        answer: 'Sí. Según el artículo 76 del Código General del Proceso, basta con radicar en la secretaría del juzgado un escrito de revocación o un nuevo poder a favor de otro abogado. La revocatoria surte efecto inmediato desde la presentación del memorial. Eso sí, el abogado revocado tiene 30 días para solicitar la regulación de honorarios mediante incidente, así que conviene tener clara la relación económica antes de revocar.',
    },
    {
        question: '¿Qué facultades tiene mi apoderado por defecto?',
        answer: 'El artículo 77 del Código General del Proceso establece que el poder para litigar autoriza al abogado para recibir la notificación del auto admisorio, prestar juramento estimatorio, confesar espontáneamente, solicitar medidas cautelares, presentar recursos y adelantar todo el proceso. Sin embargo, el apoderado NO puede recibir, transigir, conciliar ni disponer del derecho en disputa, salvo que el poderdante lo autorice expresamente en el documento. Por eso es tan importante que el poder describa con detalle las facultades especiales que quieras conceder.',
    },
    {
        question: '¿Los documentos de Grexia son generados por inteligencia artificial?',
        answer: 'No. Los documentos de Grexia nunca son generados por IA. Cada plantilla fue redactada, validada y respaldada por abogados especialistas en derecho colombiano, sin artículos inventados ni leyes fabricadas. La herramienta recopila tus datos y los aplica a una plantilla legal verificada. Para condiciones especiales o situaciones complejas, te conectamos con un profesional legal.',
    },
];

const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqPoder.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: { '@type': 'Answer', text: faq.answer },
    })),
};
---

<Layout
    title="Poder Especial en Colombia: Guía Completa - Grexia"
    description="Aprende qué es un poder especial, cuándo necesitas uno, qué exige el Código General del Proceso y los riesgos de un poder mal redactado. Genera el tuyo gratis en Grexia."
    schema={faqSchema}
>
    <main class="grow w-full">
        <!-- ─── HERO ──────────────────────────────────────────────────────── -->
        <section class="grow flex items-center justify-center">
            <div class="relative w-full max-w-7xl px-6 lg:px-8 py-8 lg:py-14">
                <!-- Breadcrumb -->
                <div class="mb-10">
                    <Breadcrumb items={[{ label: 'Guías', href: base + 'guias' }, { label: 'Poder Especial' }]} />
                </div>

                <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-20 items-center">
                    <!-- Izquierda: texto -->
                    <div class="flex flex-col gap-8 order-2 lg:order-1">
                        <!-- Trust Badges -->
                        <div class="hidden lg:flex flex-wrap gap-3">
                            {
                                trustBadges.map((badge) => (
                                    <div class="flex items-center gap-1.5 rounded-full bg-white border border-slate-200 px-3 py-1.5 shadow-sm">
                                        <span class="material-symbols-outlined text-primary text-[20px] font-bold">
                                            {badge.icon}
                                        </span>
                                        <span class="text-xs font-semibold text-slate-700 uppercase tracking-wide">
                                            {badge.label}
                                        </span>
                                    </div>
                                ))
                            }
                        </div>

                        <!-- H1 -->
                        <div class="space-y-6">
                            <h1
                                class="text-4xl font-black leading-[1.1] tracking-tight text-secondary sm:text-5xl xl:text-6xl"
                            >
                                Todo sobre el
                                <span class="relative whitespace-nowrap text-secondary">
                                    poder especial
                                    <span class="absolute bottom-1 left-0 -z-10 h-3 w-full bg-primary/40 rounded-full"
                                    ></span>
                                </span>
                                en Colombia
                            </h1>
                            <p class="max-w-lg text-lg text-slate-600 leading-relaxed">
                                Entiende qué es, cuándo lo necesitas, qué exige el Código General del Proceso y por qué
                                un poder mal redactado puede frenar todo tu proceso judicial. Y al final, genera el tuyo
                                gratis en minutos.
                            </p>
                        </div>

                        <!-- CTAs -->
                        <div class="flex flex-col sm:flex-row gap-4 pt-2">
                            <a
                                href={base + tool.href.form}
                                class="flex h-14 items-center justify-center gap-2 rounded-full bg-primary px-8 text-base font-bold text-white shadow-md shadow-primary/20 transition-all hover:-translate-y-0.5 hover:bg-primary-hover hover:shadow-lg active:translate-y-0"
                            >
                                Generar poder gratis
                                <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
                            </a>
                            <a
                                href={base + 'asesoria/checkout'}
                                class="flex h-14 items-center justify-center rounded-full bg-white border border-slate-200 px-8 text-base font-bold text-slate-700 shadow-sm transition-all hover:bg-slate-50 hover:border-slate-300"
                            >
                                Hablar con un abogado
                            </a>
                        </div>

                        <!-- Social Proof -->
                        <div class="flex items-center gap-4 pt-6 border-t border-slate-200 mt-2">
                            <div class="flex -space-x-4">
                                {
                                    socialAvatars.map((a) => (
                                        <img
                                            alt={a.alt}
                                            class="h-12 w-12 rounded-full border-2 border-white object-cover"
                                            src={a.src}
                                        />
                                    ))
                                }
                                <div
                                    class="flex h-12 w-12 items-center justify-center rounded-full border-2 border-white bg-secondary text-xs font-bold text-white"
                                >
                                    +1.2k
                                </div>
                            </div>
                            <div class="flex flex-col justify-center">
                                <div class="flex text-yellow-400 text-sm">
                                    {
                                        Array.from({ length: 5 }).map(() => (
                                            <span class="material-symbols-outlined text-[18px]">star</span>
                                        ))
                                    }
                                </div>
                                <p class="text-sm font-medium text-slate-600">
                                    Más de <span class="font-bold text-secondary">3.200 documentos</span> generados
                                </p>
                            </div>
                        </div>

                        <!-- Legal basis -->
                        <p class="text-sm text-slate-500 -mt-4">
                            Conforme a <strong class="text-slate-700"
                                >los artículos 74 y 77 del Código General del Proceso y la Ley 2213 de 2022</strong
                            >
                        </p>
                    </div>

                    <!-- Derecha: imagen -->
                    <div class="relative hidden lg:block order-1 lg:order-2">
                        <div
                            class="relative w-full aspect-4/5 md:aspect-square lg:aspect-4/5 overflow-hidden rounded-[2.5rem] bg-slate-100 shadow-2xl"
                        >
                            <img
                                alt="Poder especial en Colombia"
                                class="h-full w-full object-cover object-center"
                                src={tool.heroImage}
                            />
                            <div class="absolute inset-0 bg-linear-to-t from-secondary/20 to-transparent"></div>

                            <!-- Glass Widget: abogado -->
                            <div
                                class="glass-widget absolute top-8 right-6 flex max-w-65 flex-col gap-3 rounded-lg p-4 animate-[fade-in-up_1s_ease-out_0.5s_backwards]"
                            >
                                <div class="flex items-center gap-3">
                                    <div class="relative">
                                        <div
                                            class="h-10 w-10 rounded-full bg-primary flex items-center justify-center border border-white"
                                        >
                                            <span class="material-symbols-outlined text-white text-[20px]">person</span>
                                        </div>
                                        <div
                                            class="absolute bottom-0 right-0 h-3 w-3 rounded-full bg-green-500 border-2 border-white"
                                        >
                                        </div>
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="text-sm font-bold text-slate-800">{tool.heroLawyerName}</span>
                                        <span class="text-xs text-slate-700">{tool.heroLawyerSpecialty}</span>
                                    </div>
                                </div>
                                <div
                                    class="rounded-xl bg-white/60 p-2 text-xs text-slate-700 leading-snug backdrop-blur-sm"
                                >
                                    "{tool.heroChat}"
                                </div>
                            </div>

                            <!-- Glass Widget: guía badge -->
                            <div
                                class="glass-widget absolute bottom-8 left-6 flex items-center gap-3 rounded-full py-3 px-5 pr-8"
                            >
                                <div
                                    class="flex h-10 w-10 items-center justify-center rounded-full bg-primary text-white"
                                >
                                    <span class="material-symbols-outlined text-[24px]">menu_book</span>
                                </div>
                                <div>
                                    <p class="text-xs text-slate-700 font-medium uppercase tracking-wider">
                                        Guía completa
                                    </p>
                                    <p class="text-sm font-bold text-slate-800">Normativa vigente</p>
                                </div>
                            </div>
                        </div>

                        <!-- Blobs decorativos -->
                        <div class="absolute -top-12 -right-12 -z-10 h-64 w-64 rounded-full bg-primary/20 blur-3xl">
                        </div>
                        <div class="absolute -bottom-12 -left-12 -z-10 h-64 w-64 rounded-full bg-blue-500/10 blur-3xl">
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ─── ¿QUÉ ES? ──────────────────────────────────────────────────── -->
        <section class="bg-white py-16 lg:py-24">
            <div class="mx-auto max-w-4xl px-6 lg:px-8">
                <div class="text-center mb-12">
                    <span
                        class="inline-flex items-center gap-1.5 rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary mb-4"
                    >
                        <span class="material-symbols-outlined text-[14px]">info</span>
                        Definición legal
                    </span>
                    <h2 class="text-3xl font-black tracking-tight text-secondary sm:text-4xl">
                        ¿Qué es un poder especial?
                    </h2>
                </div>

                <!-- Definición destacada -->
                <div class="rounded-lg border-l-4 border-primary bg-slate-50 p-6 mb-10">
                    <p class="text-base text-slate-700 leading-relaxed italic">
                        "Si el mandato comprende uno o más negocios especialmente determinados, se llama especial; si se
                        da para todos los negocios del mandante, es general; y lo será igualmente si se da para todos,
                        con una o más excepciones determinadas."
                    </p>
                    <p class="mt-3 text-sm font-semibold text-primary">Código Civil colombiano, Art. 2156</p>
                </div>

                <div class="prose prose-slate max-w-none text-slate-600 text-base leading-relaxed space-y-4">
                    <p>
                        En términos simples, un poder especial es el documento por el cual una persona (el <strong
                            >poderdante</strong
                        >) autoriza a otra (el <strong>apoderado</strong>) a actuar en su nombre frente a un asunto
                        concreto y plenamente identificado: un proceso judicial, un trámite notarial o la administración
                        de un bien específico.
                    </p>
                    <p>
                        El <strong>artículo 74 del Código General del Proceso</strong> exige que en los poderes especiales
                        los asuntos estén "determinados y claramente identificados". No basta con escribir "para que me represente
                        en lo que sea necesario": hay que decir exactamente para qué proceso, contra quién y sobre qué bien.
                    </p>
                    <p>
                        Desde la <strong>Ley 2213 de 2022</strong>, el poder especial para fines judiciales puede
                        otorgarse por mensaje de datos con firma simple, sin presentación personal ni autenticación
                        notarial, y se presume auténtico cuando indica el correo electrónico del abogado registrado en
                        el Registro Nacional de Abogados.
                    </p>
                </div>

                <!-- Pills de tipo -->
                <div class="mt-10 flex flex-wrap gap-3 justify-center">
                    {
                        [
                            { icon: 'description', label: 'Para procesos judiciales', ley: 'Art. 74 CGP' },
                            { icon: 'edit_document', label: 'Para trámites notariales', ley: 'Decreto 960 de 1970' },
                            { icon: 'apartment', label: 'Para administración de bienes', ley: 'Art. 2156 C. Civil' },
                        ].map((t) => (
                            <div class="flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-4 py-3 shadow-sm">
                                <span class="material-symbols-outlined text-primary text-[20px]">{t.icon}</span>
                                <div>
                                    <p class="text-sm font-bold text-secondary">{t.label}</p>
                                    <p class="text-xs text-slate-500">{t.ley}</p>
                                </div>
                            </div>
                        ))
                    }
                </div>

                <!-- Especial vs general -->
                <div class="mt-10 rounded-lg bg-amber-50 border border-amber-200 p-5 flex gap-4">
                    <span class="material-symbols-outlined text-amber-500 text-[24px] shrink-0 mt-0.5">warning</span>
                    <div>
                        <p class="text-sm font-bold text-amber-900 mb-1">¿Especial o general?</p>
                        <p class="text-sm text-amber-800 leading-relaxed">
                            Para procesos judiciales <strong>siempre</strong> debe ser un poder especial: el juez exige que
                            el asunto esté determinado. Un poder general no sirve para iniciar una demanda concreta. El poder
                            general se usa más para administración integral del patrimonio y debe constar en escritura pública.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ─── ¿CUÁNDO NECESITAS UNO? ───────────────────────────────────── -->
        <section class="bg-neutral-50 py-16 lg:py-24">
            <div class="mx-auto max-w-5xl px-6 lg:px-8">
                <div class="text-center mb-12">
                    <h2 class="text-3xl font-black tracking-tight text-secondary sm:text-4xl">
                        ¿Cuándo necesitas un poder especial?
                    </h2>
                    <p class="mt-3 text-lg text-slate-600 max-w-xl mx-auto">
                        Cada vez que necesites que otra persona te represente en un proceso o trámite específico.
                    </p>
                </div>

                <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
                    {
                        [
                            {
                                icon: 'home_work',
                                titulo: 'Declaración de Pertenencia',
                                descripcion:
                                    'Cuando llevas años poseyendo un inmueble y quieres convertirte en propietario por prescripción adquisitiva.',
                            },
                            {
                                icon: 'gavel',
                                titulo: 'Procesos civiles, laborales o de familia',
                                descripcion:
                                    'Cuando un abogado debe representarte en un juzgado: cobro, restitución, custodia, divorcio, alimentos.',
                            },
                            {
                                icon: 'edit_document',
                                titulo: 'Trámites notariales',
                                descripcion:
                                    'Cuando no puedes asistir a firmar una escritura, una sucesión notarial o cualquier acto en notaría.',
                            },
                            {
                                icon: 'apartment',
                                titulo: 'Administración de bienes',
                                descripcion:
                                    'Cuando vives fuera del país o de la ciudad y necesitas que alguien administre tus inmuebles, cobre cánones o firme contratos.',
                            },
                        ].map((c) => (
                            <div class="rounded-lg border border-slate-200 bg-white p-7 shadow-sm">
                                <span class="mb-5 flex h-11 w-11 items-center justify-center rounded-full bg-primary/10">
                                    <span class="material-symbols-outlined text-[22px] text-primary">{c.icon}</span>
                                </span>
                                <h3 class="text-base font-black text-secondary mb-2">{c.titulo}</h3>
                                <p class="text-sm text-slate-600 leading-relaxed">{c.descripcion}</p>
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- ─── MARCO LEGAL ───────────────────────────────────────────────── -->
        <section class="bg-white py-16 lg:py-24">
            <div class="mx-auto max-w-4xl px-6 lg:px-8">
                <div class="text-center mb-12">
                    <span
                        class="inline-flex items-center gap-1.5 rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary mb-4"
                    >
                        <span class="material-symbols-outlined text-[14px]">balance</span>
                        Normatividad
                    </span>
                    <h2 class="text-3xl font-black tracking-tight text-secondary sm:text-4xl">
                        ¿Bajo qué normativa se rige?
                    </h2>
                    <p class="mt-3 text-lg text-slate-600 max-w-xl mx-auto">
                        Cuatro normas se combinan para regular el poder especial en Colombia.
                    </p>
                </div>

                <div class="flex flex-col gap-6">
                    {
                        [
                            {
                                norma: 'Código Civil, Art. 2156',
                                year: '1887',
                                color: 'bg-slate-100 border-slate-300',
                                textColor: 'text-slate-600',
                                titulo: 'Definición de mandato especial y general',
                                descripcion:
                                    'Es la norma raíz: define qué es el mandato y diferencia el poder especial (para asuntos determinados) del poder general (para todos los negocios). Aplica a todo tipo de poder, judicial o extrajudicial.',
                            },
                            {
                                norma: 'Decreto 196 de 1971',
                                year: '1971',
                                color: 'bg-blue-50 border-blue-200',
                                textColor: 'text-blue-700',
                                titulo: 'Estatuto del ejercicio de la abogacía',
                                descripcion:
                                    'Establece que para representar a otro en un proceso judicial se requiere ser abogado titulado, con tarjeta profesional vigente expedida por el Consejo Superior de la Judicatura. Sin tarjeta profesional, el abogado no tiene derecho de postulación.',
                            },
                            {
                                norma: 'Ley 1564 de 2012, Arts. 74, 76 y 77',
                                year: '2012',
                                color: 'bg-primary/10 border-primary/30',
                                textColor: 'text-primary',
                                titulo: 'Código General del Proceso',
                                descripcion:
                                    'Es el corazón normativo del poder judicial. El Art. 74 regula cómo se otorga, el Art. 76 cómo termina y el Art. 77 las facultades del apoderado por defecto. Exige que los asuntos del poder especial estén determinados y claramente identificados.',
                            },
                            {
                                norma: 'Ley 2213 de 2022',
                                year: '2022',
                                color: 'bg-emerald-50 border-emerald-200',
                                textColor: 'text-emerald-700',
                                titulo: 'Justicia digital permanente',
                                descripcion:
                                    'Convirtió en permanentes las normas del Decreto 806 de 2020. Permite otorgar el poder especial por mensaje de datos con firma simple, sin presentación personal ni autenticación notarial, siempre que se indique el correo del abogado registrado en el RNA.',
                            },
                        ].map((n) => (
                            <div class={`rounded-lg border ${n.color} p-6 flex gap-5`}>
                                <div class="shrink-0 text-center">
                                    <span class={`text-xs font-black uppercase tracking-wider ${n.textColor}`}>
                                        {n.year}
                                    </span>
                                </div>
                                <div>
                                    <p class={`text-xs font-bold uppercase tracking-wider ${n.textColor} mb-1`}>
                                        {n.norma}
                                    </p>
                                    <h3 class="text-base font-black text-secondary mb-1">{n.titulo}</h3>
                                    <p class="text-sm text-slate-600 leading-relaxed">{n.descripcion}</p>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>
