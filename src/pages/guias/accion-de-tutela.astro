---
import Layout from '../../layouts/Layout.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import Breadcrumb from '../../components/shared/Breadcrumb.astro';
import FAQAccordion from '../../components/shared/FAQAccordion.tsx';
import { TOOLS } from '../../config/tools';

const base = import.meta.env.BASE_URL;
const tool = TOOLS.find((t) => t.slug === 'tutela')!;

const trustBadges = [
    { icon: 'balance', label: 'Marco legal vigente' },
    { icon: 'lock', label: 'Sin registro' },
    { icon: 'picture_as_pdf', label: 'PDF en 1 minuto' },
];

const socialAvatars = [
    {
        src: 'https://lh3.googleusercontent.com/aida-public/AB6AXuD5V-on_7keAJEftPazMB7vJ67iatf4qd4WOg_ZLAGyQBUYYmpcgWK5CelWduBdraqtPEVMpbZacLQTptHErkMPUSMqVXJe326yqQ1W5TwXEGPS4jEK_qNcJlia7lnzWXHb8dHj4yFQ0yb8dgypVkMEydK7l4KuqFSfMe08sorNHA100WBaGKGVLRDnkqDwuhJaz29ykI2nxkBUGnMcdVoXgJQJLSjQy3dkBNGn3kCa3dXugbVN6ZcyTay7ASuwwRvKF5m__5lVmKDy',
        alt: 'Usuaria de Grexia',
    },
    {
        src: 'https://lh3.googleusercontent.com/aida-public/AB6AXuCfp-jh4m6Wbqi9eNLW5obsxwye-auLWzPod3k8AJEROlnlaC_1aesC1FHe7w3PXdQekpmc1AW1_i3T5me0j8M5OUwqa88kbLcNPK3-4JyenI6zUb4QR6Av2Yh4wh10lu4brK_rCWq_2EIcu93vRZ4rWuRPfxhmVwSAVnZVNXWprqEEhh8Pv6fQZO5Hir-sQmpAv-PUqk9Lx0iPvBHpG-Ufxf9VoI2PTL81xeLGJ_9uZ5UabQYR-HFeNlBSdNJxQeWQyU2Tj0VbSAw9',
        alt: 'Usuario de Grexia',
    },
    {
        src: 'https://lh3.googleusercontent.com/aida-public/AB6AXuDCX5Y3IuUrv_PQkgw7I4x0hIq5GvqM4mNZH8Nf77tl1GcPXLaCsLSP2o-hJE_jkQBylIIrWbA_Agy1XvGpz_f8DUANpGrude4HanBLTVn0rjk9MH1DWXBs_2XcoV0BjA2Jv0TSycQXYoMDCFQ6jRTvQ7EqpI_UR5w-Hc1GzrtD-_-1gqsnysbzsx96QlqhDIlsLbggTZolxZyvIOnJ4GSC_Nr2qTSas446QFjH9RInxio5Jobdsm1Lu_97Tf-dswOGBLAidqyvqKbw',
        alt: 'Usuario de Grexia',
    },
];

const faqTutela = [
    {
        question: '¿Cuánto tarda un juez en fallar una tutela en Colombia?',
        answer: 'El artículo 86 de la Constitución y el artículo 29 del Decreto 2591 de 1991 establecen un plazo máximo de 10 días contados desde la presentación de la tutela para que el juez profiera el fallo. Es un procedimiento preferente y sumario, por lo que el juez debe darle prioridad sobre cualquier otro asunto. El fallo es de inmediato cumplimiento, incluso si la EPS lo impugna.',
    },
    {
        question: '¿Ante qué juez se presenta una tutela contra una EPS?',
        answer: 'En Colombia rige la competencia promiscua: cualquier juez del lugar donde ocurrió la vulneración o tenga efectos puede conocer la tutela. El Decreto 1382 de 2000 fija reglas de reparto, no de competencia. La Corte Constitucional ha sido clara: ningún juez puede negarse a fallar una tutela invocando ese decreto. Para tutelas en salud generalmente conocen los Jueces Civiles o Penales del Circuito.',
    },
    {
        question: '¿Qué es el principio de subsidiariedad y cuándo impide la tutela?',
        answer: 'La tutela solo procede cuando no existe otro mecanismo judicial idóneo y eficaz para proteger el derecho, salvo que se use como mecanismo transitorio para evitar un perjuicio irremediable. En salud, la jurisprudencia es flexible: tratándose de un derecho fundamental autónomo (Ley 1751 de 2015), generalmente la tutela procede sin agotar otros recursos administrativos.',
    },
    {
        question: '¿Qué pasa si la EPS me niega un servicio prescrito por mi médico tratante?',
        answer: 'Cuando el médico tratante prescribe un servicio (incluso por MIPRES si está fuera del Plan de Beneficios), la EPS debe entregarlo en máximo 5 días. Si lo niega, la jurisprudencia constitucional desde la Sentencia T-760 de 2008 ha sido reiterativa: prevalece el criterio del médico tratante y la tutela procede para ordenar la entrega inmediata, incluyendo medicamentos no PBS, transporte y tratamientos integrales.',
    },
    {
        question: '¿Puedo impugnar el fallo si el juez niega mi tutela?',
        answer: 'Sí. El artículo 31 del Decreto 2591 de 1991 te da 3 días hábiles desde la notificación del fallo para impugnarlo ante el juez de segunda instancia (un juez de mayor jerarquía). El juez de impugnación tiene 20 días para resolver. Aunque el fallo se confirme, la Corte Constitucional puede seleccionarlo para revisión y cambiar la decisión.',
    },
    {
        question: '¿Necesito abogado para presentar una tutela?',
        answer: 'No. El artículo 86 de la Constitución permite que cualquier persona presente la tutela por sí misma, sin abogado, sin formalidades especiales y en cualquier momento. Por eso herramientas como Grexia te permiten redactar la tutela tú mismo. Eso sí: una tutela mal redactada, sin pruebas o presentada ante el juez incorrecto puede ser rechazada in limine.',
    },
];

const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqTutela.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: { '@type': 'Answer', text: faq.answer },
    })),
};
---

<Layout
    title="Acción de Tutela en Colombia: Guía Completa | Grexia"
    description="Aprende qué es la acción de tutela, cuándo procede contra una EPS, qué dice el Art. 86 de la Constitución y cómo redactar la tuya. Genera tu tutela gratis en Grexia."
    canonical="https://grexia.co/guias/accion-de-tutela"
    schema={faqSchema}
>
    <main class="grow w-full">
        <!-- ─── HERO ──────────────────────────────────────────────────────── -->
        <section class="grow flex items-center justify-center">
            <div class="relative w-full max-w-7xl px-6 lg:px-8 py-8 lg:py-14">
                <!-- Breadcrumb -->
                <div class="mb-10">
                    <Breadcrumb items={[{ label: 'Guías', href: base + 'guias' }, { label: 'Acción de Tutela' }]} />
                </div>

                <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-20 items-center">
                    <!-- Izquierda: texto -->
                    <div class="flex flex-col gap-8 order-2 lg:order-1">
                        <!-- Trust Badges -->
                        <div class="hidden lg:flex flex-wrap gap-3">
                            {
                                trustBadges.map((badge) => (
                                    <div class="flex items-center gap-1.5 rounded-full bg-white border border-slate-200 px-3 py-1.5 shadow-sm">
                                        <span class="material-symbols-outlined text-primary text-[20px] font-bold">
                                            {badge.icon}
                                        </span>
                                        <span class="text-xs font-semibold text-slate-700 uppercase tracking-wide">
                                            {badge.label}
                                        </span>
                                    </div>
                                ))
                            }
                        </div>

                        <!-- H1 -->
                        <div class="space-y-6">
                            <h1
                                class="text-4xl font-black leading-[1.1] tracking-tight text-secondary sm:text-5xl xl:text-6xl"
                            >
                                Todo sobre la acción de
                                <span class="relative whitespace-nowrap text-secondary">
                                    tutela
                                    <span class="absolute bottom-1 left-0 -z-10 h-3 w-full bg-primary/40 rounded-full"
                                    ></span>
                                </span>
                                en Colombia
                            </h1>
                            <p class="max-w-lg text-lg text-slate-600 leading-relaxed">
                                Es el mecanismo más poderoso que tienes para proteger tus derechos fundamentales en
                                Colombia. Aprende cómo funciona, cuándo procede contra tu EPS y por qué redactarla mal
                                puede costarte tu salud. Y al final, genera la tuya gratis en minutos.
                            </p>
                        </div>

                        <!-- CTAs -->
                        <div class="flex flex-col sm:flex-row gap-4 pt-2">
                            <a
                                href={base + tool.href.form}
                                class="flex h-14 items-center justify-center gap-2 rounded-full bg-primary px-8 text-base font-bold text-white shadow-md shadow-primary/20 transition-all hover:-translate-y-0.5 hover:bg-primary-hover hover:shadow-lg active:translate-y-0"
                            >
                                Generar tutela gratis
                                <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
                            </a>
                            <a
                                href={base + 'asesoria/checkout'}
                                class="flex h-14 items-center justify-center rounded-full bg-white border border-slate-200 px-8 text-base font-bold text-slate-700 shadow-sm transition-all hover:bg-slate-50 hover:border-slate-300"
                            >
                                Hablar con un abogado
                            </a>
                        </div>

                        <!-- Social Proof -->
                        <div class="flex items-center gap-4 pt-6 border-t border-slate-200 mt-2">
                            <div class="flex -space-x-4">
                                {
                                    socialAvatars.map((a) => (
                                        <img
                                            alt={a.alt}
                                            class="h-12 w-12 rounded-full border-2 border-white object-cover"
                                            src={a.src}
                                        />
                                    ))
                                }
                                <div
                                    class="flex h-12 w-12 items-center justify-center rounded-full border-2 border-white bg-secondary text-xs font-bold text-white"
                                >
                                    +1.2k
                                </div>
                            </div>
                            <div class="flex flex-col justify-center">
                                <div class="flex text-yellow-400 text-sm">
                                    {
                                        Array.from({ length: 5 }).map(() => (
                                            <span class="material-symbols-outlined text-[18px]">star</span>
                                        ))
                                    }
                                </div>
                                <p class="text-sm font-medium text-slate-600">
                                    Más de <span class="font-bold text-secondary">3.200 documentos</span> generados
                                </p>
                            </div>
                        </div>

                        <!-- Legal basis -->
                        <p class="text-sm text-slate-500 -mt-4">
                            Conforme al
                            <strong class="text-slate-700"
                                >Art. 86 de la Constitución Política, el Decreto 2591 de 1991 y la Ley 1751 de 2015</strong
                            >
                        </p>
                    </div>

                    <!-- Derecha: imagen -->
                    <div class="relative hidden lg:block order-1 lg:order-2">
                        <div
                            class="relative w-full aspect-4/5 md:aspect-square lg:aspect-4/5 overflow-hidden rounded-[2.5rem] bg-slate-100 shadow-2xl"
                        >
                            <img
                                alt="Acción de tutela en Colombia"
                                class="h-full w-full object-cover object-center"
                                src={tool.heroImage}
                            />
                            <div class="absolute inset-0 bg-linear-to-t from-secondary/20 to-transparent"></div>

                            <!-- Glass Widget: abogado -->
                            <div
                                class="glass-widget absolute top-8 right-6 flex max-w-65 flex-col gap-3 rounded-lg p-4 animate-[fade-in-up_1s_ease-out_0.5s_backwards]"
                            >
                                <div class="flex items-center gap-3">
                                    <div class="relative">
                                        <div
                                            class="h-10 w-10 rounded-full bg-primary flex items-center justify-center border border-white overflow-hidden"
                                        >
                                            <img
                                                alt={tool.heroLawyerName}
                                                class="h-full w-full object-cover"
                                                src={tool.heroLawyerAvatar}
                                            />
                                        </div>
                                        <div
                                            class="absolute bottom-0 right-0 h-3 w-3 rounded-full bg-green-500 border-2 border-white"
                                        >
                                        </div>
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="text-sm font-bold text-slate-800">{tool.heroLawyerName}</span>
                                        <span class="text-xs text-slate-700">{tool.heroLawyerSpecialty}</span>
                                    </div>
                                </div>
                                <div
                                    class="rounded-xl bg-white/60 p-2 text-xs text-slate-700 leading-snug backdrop-blur-sm"
                                >
                                    "{tool.heroChat}"
                                </div>
                            </div>

                            <!-- Glass Widget: guía badge -->
                            <div
                                class="glass-widget absolute bottom-8 left-6 flex items-center gap-3 rounded-full py-3 px-5 pr-8"
                            >
                                <div
                                    class="flex h-10 w-10 items-center justify-center rounded-full bg-primary text-white"
                                >
                                    <span class="material-symbols-outlined text-[24px]">menu_book</span>
                                </div>
                                <div>
                                    <p class="text-xs text-slate-700 font-medium uppercase tracking-wider">
                                        Guía completa
                                    </p>
                                    <p class="text-sm font-bold text-slate-800">Normativa vigente</p>
                                </div>
                            </div>
                        </div>

                        <!-- Blobs decorativos -->
                        <div class="absolute -top-12 -right-12 -z-10 h-64 w-64 rounded-full bg-primary/20 blur-3xl">
                        </div>
                        <div class="absolute -bottom-12 -left-12 -z-10 h-64 w-64 rounded-full bg-blue-500/10 blur-3xl">
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ─── ¿QUÉ ES? ──────────────────────────────────────────────────── -->
        <section class="bg-white py-16 lg:py-24">
            <div class="mx-auto max-w-4xl px-6 lg:px-8">
                <div class="text-center mb-12">
                    <span
                        class="inline-flex items-center gap-1.5 rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary mb-4"
                    >
                        <span class="material-symbols-outlined text-[14px]">info</span>
                        Definición legal
                    </span>
                    <h2 class="text-3xl font-black tracking-tight text-secondary sm:text-4xl">
                        ¿Qué es la acción de tutela?
                    </h2>
                </div>

                <!-- Definición destacada -->
                <div class="rounded-lg border-l-4 border-primary bg-slate-50 p-6 mb-10">
                    <p class="text-base text-slate-700 leading-relaxed italic">
                        "Toda persona tendrá acción de tutela para reclamar ante los jueces, en todo momento y lugar,
                        mediante un procedimiento preferente y sumario, por sí misma o por quien actúe a su nombre, la
                        protección inmediata de sus derechos constitucionales fundamentales, cuando quiera que éstos
                        resulten vulnerados o amenazados por la acción o la omisión de cualquier autoridad pública."
                    </p>
                    <p class="mt-3 text-sm font-semibold text-primary">Constitución Política de Colombia, Art. 86</p>
                </div>

                <div class="prose prose-slate max-w-none text-slate-600 text-base leading-relaxed space-y-4">
                    <p>
                        En palabras sencillas, la tutela es el mecanismo más rápido y poderoso que tienes para proteger
                        tus derechos fundamentales en Colombia. No requiere abogado, no tiene costo y el juez tiene un
                        máximo de <strong>10 días</strong> para fallar. Cualquier persona puede presentarla, en cualquier
                        momento y ante cualquier juez del país.
                    </p>
                    <p>
                        En el contexto de salud, la tutela es la herramienta más usada para que las EPS cumplan con su
                        obligación. La <strong>Ley 1751 de 2015</strong> consagró la salud como un derecho fundamental autónomo,
                        y la <strong>Sentencia T-760 de 2008</strong> de la Corte Constitucional marcó el hito que hoy permite
                        tutelar negativas de medicamentos, procedimientos, exámenes y tratamientos.
                    </p>
                </div>

                <!-- Pills de derechos protegibles -->
                <div class="mt-10 flex flex-wrap gap-3 justify-center">
                    {
                        [
                            { icon: 'health_and_safety', label: 'Derecho a la salud', ley: 'Ley 1751 de 2015' },
                            { icon: 'favorite', label: 'Vida y dignidad', ley: 'Art. 11 y 12 C.P.' },
                            { icon: 'family_restroom', label: 'Mínimo vital', ley: 'Jurisprudencia C.C.' },
                        ].map((t) => (
                            <div class="flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-4 py-3 shadow-sm">
                                <span class="material-symbols-outlined text-primary text-[20px]">{t.icon}</span>
                                <div>
                                    <p class="text-sm font-bold text-secondary">{t.label}</p>
                                    <p class="text-xs text-slate-500">{t.ley}</p>
                                </div>
                            </div>
                        ))
                    }
                </div>

                <!-- Subsidiariedad e Inmediatez -->
                <div class="mt-10 rounded-lg bg-amber-50 border border-amber-200 p-5 flex gap-4">
                    <span class="material-symbols-outlined text-amber-500 text-[24px] shrink-0 mt-0.5">warning</span>
                    <div>
                        <p class="text-sm font-bold text-amber-900 mb-1">Dos requisitos que pueden tumbar tu tutela</p>
                        <p class="text-sm text-amber-800 leading-relaxed">
                            <strong>Subsidiariedad</strong>: la tutela no procede si tienes otro mecanismo judicial
                            eficaz. <strong>Inmediatez</strong>: debes presentarla en un tiempo razonable desde la
                            vulneración. En tutelas de salud, la jurisprudencia es flexible cuando el derecho
                            fundamental está en juego, pero una tutela mal redactada puede ser rechazada in limine.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ─── ¿CUÁNDO PROCEDE? ─────────────────────────────────────────── -->
        <section class="bg-neutral-50 py-16 lg:py-24">
            <div class="mx-auto max-w-5xl px-6 lg:px-8">
                <div class="text-center mb-12">
                    <h2 class="text-3xl font-black tracking-tight text-secondary sm:text-4xl">
                        ¿Cuándo procede una tutela contra tu EPS?
                    </h2>
                    <p class="mt-3 text-lg text-slate-600 max-w-xl mx-auto">
                        Si tu EPS niega, demora o condiciona un servicio prescrito por tu médico, la tutela es tu
                        herramienta.
                    </p>
                </div>

                <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
                    {
                        [
                            {
                                icon: 'medical_services',
                                titulo: 'Negativa de procedimientos',
                                descripcion:
                                    'Cuando la EPS no autoriza una cirugía, examen o procedimiento prescrito por tu médico tratante. La jurisprudencia es clara: prevalece el criterio médico.',
                            },
                            {
                                icon: 'pill',
                                titulo: 'Medicamentos negados',
                                descripcion:
                                    'Cuando la EPS no entrega un medicamento prescrito por MIPRES o aduce que no está en el Plan de Beneficios. La Sentencia T-760 de 2008 permite ordenar su entrega.',
                            },
                            {
                                icon: 'schedule',
                                titulo: 'Demora excesiva',
                                descripcion:
                                    'Cuando la EPS demora la atención de forma irrazonable. Si el servicio fue ordenado por MIPRES, el plazo máximo es de 5 días. Después, hay vulneración.',
                            },
                        ].map((c) => (
                            <div class="rounded-lg border border-slate-200 bg-white p-7 shadow-sm">
                                <span class="mb-5 flex h-11 w-11 items-center justify-center rounded-full bg-primary/10">
                                    <span class="material-symbols-outlined text-[22px] text-primary">{c.icon}</span>
                                </span>
                                <h3 class="text-base font-black text-secondary mb-2">{c.titulo}</h3>
                                <p class="text-sm text-slate-600 leading-relaxed">{c.descripcion}</p>
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- ─── MARCO LEGAL ───────────────────────────────────────────────── -->
        <section class="bg-white py-16 lg:py-24">
            <div class="mx-auto max-w-4xl px-6 lg:px-8">
                <div class="text-center mb-12">
                    <span
                        class="inline-flex items-center gap-1.5 rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary mb-4"
                    >
                        <span class="material-symbols-outlined text-[14px]">balance</span>
                        Normatividad
                    </span>
                    <h2 class="text-3xl font-black tracking-tight text-secondary sm:text-4xl">
                        ¿Bajo qué normativa se rige?
                    </h2>
                    <p class="mt-3 text-lg text-slate-600 max-w-xl mx-auto">
                        La tutela tiene rango constitucional. Estas son las tres normas que la rigen.
                    </p>
                </div>

                <div class="flex flex-col gap-6">
                    {
                        [
                            {
                                norma: 'Constitución Política, Art. 86',
                                year: '1991',
                                color: 'bg-primary/10 border-primary/30',
                                textColor: 'text-primary',
                                titulo: 'Origen constitucional de la tutela',
                                descripcion:
                                    'Crea la acción de tutela como mecanismo de protección inmediata de los derechos fundamentales. Establece que el fallo es de inmediato cumplimiento y fija el plazo máximo de 10 días para que el juez decida.',
                            },
                            {
                                norma: 'Decreto 2591 de 1991',
                                year: '1991',
                                color: 'bg-slate-100 border-slate-300',
                                textColor: 'text-slate-600',
                                titulo: 'Procedimiento de la acción de tutela',
                                descripcion:
                                    'Reglamenta el trámite. Define la competencia (Art. 37), el contenido del fallo (Art. 29), el plazo de 3 días hábiles para impugnar (Art. 31) y los casos en que procede contra particulares (Art. 42), incluidas las EPS.',
                            },
                            {
                                norma: 'Ley Estatutaria 1751 de 2015',
                                year: '2015',
                                color: 'bg-blue-50 border-blue-200',
                                textColor: 'text-blue-700',
                                titulo: 'Salud como derecho fundamental autónomo',
                                descripcion:
                                    'Reconoce la salud como derecho fundamental autónomo e irrenunciable. Establece principios de continuidad, oportunidad y pro homine. Es el respaldo legal directo para tutelar negativas de EPS sin agotar vías administrativas.',
                            },
                        ].map((n) => (
                            <div class={`rounded-lg border ${n.color} p-6 flex gap-5`}>
                                <div class="shrink-0 text-center">
                                    <span class={`text-xs font-black uppercase tracking-wider ${n.textColor}`}>
                                        {n.year}
                                    </span>
                                </div>
                                <div>
                                    <p class={`text-xs font-bold uppercase tracking-wider ${n.textColor} mb-1`}>
                                        {n.norma}
                                    </p>
                                    <h3 class="text-base font-black text-secondary mb-1">{n.titulo}</h3>
                                    <p class="text-sm text-slate-600 leading-relaxed">{n.descripcion}</p>
                                </div>
                            </div>
                        ))
                    }
                </div>

                <!-- Sentencia clave -->
                <div class="mt-8 rounded-lg bg-secondary p-6 text-center">
                    <span
                        class="inline-flex items-center gap-1.5 rounded-full bg-white/15 px-3 py-1 text-xs font-semibold text-white mb-3"
                    >
                        <span class="material-symbols-outlined text-[14px]">star</span>
                        Hito jurisprudencial
                    </span>
                    <h3 class="text-lg font-black text-white mb-2">Sentencia T-760 de 2008</h3>
                    <p class="text-sm text-blue-100/80 leading-relaxed max-w-2xl mx-auto">
                        La Corte Constitucional acumuló 22 tutelas en salud y declaró 35 órdenes estructurales. Es la
                        decisión que reconoce la salud como derecho fundamental tutelable y que sostiene hoy miles de
                        fallos contra EPS por negativas o demoras en la atención.
                    </p>
                </div>
            </div>
        </section>

        <!-- ─── PARTES DE LA TUTELA ──────────────────────────────────────── -->
        <section class="bg-neutral-50 py-16 lg:py-24">
            <div class="mx-auto max-w-5xl px-6 lg:px-8">
                <div class="text-center mb-12">
                    <h2 class="text-3xl font-black tracking-tight text-secondary sm:text-4xl">
                        ¿Quiénes participan en la tutela?
                    </h2>
