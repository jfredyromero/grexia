---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/shared/Navbar.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout title="Página no encontrada · Lexia">
    <Navbar variant="home" />
    <main class="grow flex items-center justify-center px-6">
        <div class="text-center max-w-lg">
            <p class="text-8xl font-black text-primary/20 leading-none select-none">404</p>
            <h1 class="mt-4 text-2xl font-black text-secondary tracking-tight">Página no encontrada</h1>
            <p class="mt-3 text-slate-500 leading-relaxed">
                La página que buscas no existe o fue movida. Puedes volver al inicio y explorar nuestras herramientas
                legales.
            </p>
            <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
                <a
                    href="/"
                    class="flex h-12 items-center justify-center gap-2 rounded-full bg-primary px-7 text-sm font-bold text-white shadow-md shadow-primary/20 transition-all hover:translate-y-[-2px] hover:bg-primary-hover"
                >
                    <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                    Volver al inicio
                </a>
                <a
                    href="/#herramientas"
                    class="flex h-12 items-center justify-center rounded-full bg-white border border-slate-200 px-7 text-sm font-bold text-slate-700 transition-all hover:bg-slate-50 hover:border-slate-300"
                >
                    Ver herramientas
                </a>
            </div>
        </div>
    </main>
    <WhatsAppButton />
</Layout>
