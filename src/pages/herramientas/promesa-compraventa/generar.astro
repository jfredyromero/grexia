---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/shared/Breadcrumb.astro';
import WhatsAppButton from '../../../components/WhatsAppButton.astro';
import CompraventaForm from '../../../components/compraventa/CompraventaForm';
import UpsellWidget from '../../../components/shared/UpsellWidget.astro';
import { getToolBySlug } from '../../../config/tools';

const tool = getToolBySlug('promesa-compraventa')!;
const base = import.meta.env.BASE_URL;
---

<Layout
    title="Genera tu Promesa de Compraventa - Grexia"
    description="Completa el formulario y genera tu promesa de compraventa en segundos. Documento legal listo para descargar en PDF."
    navbarVariant="tool-form"
    navbarActiveTool="promesa-compraventa"
>
    <main class="grow w-full bg-background-light">
        <div class="mx-auto max-w-7xl px-6 lg:px-8 py-8 lg:py-14">
            <!-- Page header -->
            <div class="mb-8">
                <Breadcrumb
                    items={[
                        { label: 'Herramientas', href: base + 'herramientas' },
                        { label: tool.name, href: base + tool.href.landing },
                        { label: 'Generar' },
                    ]}
                />
                <h1 class="text-3xl font-black text-secondary mt-3">Genera tu promesa de compraventa</h1>
                <div class="flex flex-wrap gap-3 mt-2">
                    <span class="inline-flex items-center gap-1 text-xs font-semibold text-slate-500">
                        <span class="material-symbols-outlined text-primary text-[16px]">check_circle</span>
                        Gratis
                    </span>
                    <span class="inline-flex items-center gap-1 text-xs font-semibold text-slate-500">
                        <span class="material-symbols-outlined text-primary text-[16px]">check_circle</span>
                        Sin registro
                    </span>
                    <span class="inline-flex items-center gap-1 text-xs font-semibold text-slate-500">
                        <span class="material-symbols-outlined text-primary text-[16px]">check_circle</span>
                        Valido en Colombia - Codigo Civil
                    </span>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 items-start gap-8">
                <div class="lg:col-span-2">
                    <CompraventaForm client:only="react" />
                </div>
                <aside class="no-print lg:sticky lg:top-[50vh] lg:-translate-y-1/2">
                    <UpsellWidget />
                </aside>
            </div>
        </div>
    </main>
    <WhatsAppButton />
</Layout>
