---
import Layout from '../../../layouts/Layout.astro';
import ToolHero from '../../../components/tools/ToolHero.astro';
import ToolHowItWorks from '../../../components/tools/ToolHowItWorks.astro';
import SharedPricing from '../../../components/shared/SharedPricing.astro';
import WhatsAppButton from '../../../components/WhatsAppButton.astro';
import { getToolBySlug } from '../../../config/tools';

const tool = getToolBySlug('promesa-compraventa')!;
const toolSchema = {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: tool.name,
    description: tool.description,
    applicationCategory: 'BusinessApplication',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'COP' },
    operatingSystem: 'Web',
    url: new URL(tool.href.landing, Astro.site).href,
};
---

<Layout
    title="Promesa de Compraventa Gratis - Grexia"
    description="Genera tu promesa de compraventa gratis en Colombia. Cumple con el Art. 1611 del Código Civil, redactada por abogados, lista para descargar en PDF."
    navbarVariant="tool-landing"
    navbarActiveTool="promesa-compraventa"
    schema={toolSchema}
>
    <ToolHero tool={tool} />
    <ToolHowItWorks tool={tool} />
    <SharedPricing />
    <WhatsAppButton />
</Layout>
