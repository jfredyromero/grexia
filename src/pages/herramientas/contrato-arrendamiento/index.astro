---
import Layout from '../../../layouts/Layout.astro';
import ToolHero from '../../../components/tools/ToolHero.astro';
import ToolHowItWorks from '../../../components/tools/ToolHowItWorks.astro';
import SharedPricing from '../../../components/shared/SharedPricing.astro';
import WhatsAppButton from '../../../components/WhatsAppButton.astro';
import { getToolBySlug } from '../../../config/tools';

const tool = getToolBySlug('contrato-arrendamiento')!;
---

<Layout
    title="Contrato de Arrendamiento - Grexia"
    description="Genera tu contrato de arrendamiento gratis en Colombia. Cumple con la Ley 820 de 2003, redactado por abogados, listo para descargar en PDF."
    navbarVariant="tool-landing"
    navbarActiveTool="contrato-arrendamiento"
>
    <ToolHero tool={tool} />
    <ToolHowItWorks tool={tool} />
    <SharedPricing />
    <WhatsAppButton />
</Layout>
