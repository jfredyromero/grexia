---
import Layout from '../../../layouts/Layout.astro';
import ToolHero from '../../../components/tools/ToolHero.astro';
import ToolHowItWorks from '../../../components/tools/ToolHowItWorks.astro';
import SharedPricing from '../../../components/shared/SharedPricing.astro';
import WhatsAppButton from '../../../components/WhatsAppButton.astro';
import { getToolBySlug } from '../../../config/tools';

const tool = getToolBySlug('liquidacion-de-intereses')!;
const toolSchema = {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: tool.name,
    description: tool.description,
    applicationCategory: 'BusinessApplication',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'COP' },
    operatingSystem: 'Web',
    url: new URL(tool.href.landing, Astro.site).href,
};
---

<Layout
    title="Liquidador de Intereses Judiciales - Grexia"
    description="Calcula intereses corrientes y moratorios en Colombia. Tasas oficiales de la Superfinanciera, resultado listo para usar en tu proceso judicial."
    navbarVariant="tool-landing"
    navbarActiveTool="liquidacion-de-intereses"
    schema={toolSchema}
>
    <ToolHero tool={tool} />
    <ToolHowItWorks tool={tool} />
    <SharedPricing />
    <WhatsAppButton />
</Layout>
