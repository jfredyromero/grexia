---
import Layout from '../../../layouts/Layout.astro';
import ToolHero from '../../../components/tools/ToolHero.astro';
import ToolHowItWorks from '../../../components/tools/ToolHowItWorks.astro';
import SharedPricing from '../../../components/shared/SharedPricing.astro';
import WhatsAppButton from '../../../components/WhatsAppButton.astro';
import { getToolBySlug } from '../../../config/tools';

const tool = getToolBySlug('pagare')!;
---

<Layout
    title="Generador de Pagaré - Grexia"
    description="Genera tu pagaré gratis en Colombia. Título valor con validez legal según el Código de Comercio, redactado por abogados, listo para descargar en PDF."
    navbarVariant="tool-landing"
    navbarActiveTool="pagare"
>
    <ToolHero tool={tool} />
    <ToolHowItWorks tool={tool} />
    <SharedPricing />
    <WhatsAppButton />
</Layout>
