---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/shared/Navbar.astro';
import Breadcrumb from '../../../components/shared/Breadcrumb.astro';
import WhatsAppButton from '../../../components/WhatsAppButton.astro';
import PagareForm from '../../../components/pagare/PagareForm';
import { getToolBySlug } from '../../../config/tools';

const tool = getToolBySlug('pagare')!;
---

<Layout title="Generador de Pagaré · Lexia">
    <Navbar
        variant="tool-form"
        activeTool="pagare"
    />
    <main class="grow w-full bg-background-light">
        <div class="mx-auto max-w-7xl px-6 lg:px-8 py-8 lg:py-14">
            <!-- Page header -->
            <div class="mb-8">
                <Breadcrumb
                    items={[
                        { label: 'Herramientas', href: '/#herramientas' },
                        { label: tool.name, href: tool.href.landing },
                        { label: 'Generar' },
                    ]}
                />
                <h1 class="text-3xl font-black text-secondary mt-3">Genera tu pagaré</h1>
                <div class="flex flex-wrap gap-3 mt-2">
                    <span class="inline-flex items-center gap-1 text-xs font-semibold text-slate-500">
                        <span class="material-symbols-outlined text-primary text-[16px]">check_circle</span>
                        Gratis
                    </span>
                    <span class="inline-flex items-center gap-1 text-xs font-semibold text-slate-500">
                        <span class="material-symbols-outlined text-primary text-[16px]">check_circle</span>
                        Sin registro
                    </span>
                    <span class="inline-flex items-center gap-1 text-xs font-semibold text-slate-500">
                        <span class="material-symbols-outlined text-primary text-[16px]">check_circle</span>
                        Válido en Colombia · Código de Comercio
                    </span>
                </div>
            </div>

            <!-- React island: full form with internal layout -->
            <PagareForm client:load />
        </div>
    </main>
    <WhatsAppButton />
</Layout>
