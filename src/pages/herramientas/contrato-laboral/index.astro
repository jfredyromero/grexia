---
import Layout from '../../../layouts/Layout.astro';
import ToolHero from '../../../components/tools/ToolHero.astro';
import ToolHowItWorks from '../../../components/tools/ToolHowItWorks.astro';
import SharedPricing from '../../../components/shared/SharedPricing.astro';
import WhatsAppButton from '../../../components/WhatsAppButton.astro';
import { getToolBySlug } from '../../../config/tools';

const tool = getToolBySlug('contrato-laboral')!;
---

<Layout
    title="Generador de Contrato Laboral - Grexia"
    description="Genera tu contrato laboral gratis en Colombia. Cumple con el Código Sustantivo del Trabajo, redactado por abogados, listo para descargar en PDF."
    navbarVariant="tool-landing"
    navbarActiveTool="contrato-laboral"
>
    <ToolHero tool={tool} />
    <ToolHowItWorks tool={tool} />
    <SharedPricing />
    <WhatsAppButton />
</Layout>
