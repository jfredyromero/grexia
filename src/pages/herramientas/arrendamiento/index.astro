---
import Layout from '../../../layouts/Layout.astro';
import ToolHero from '../../../components/tools/ToolHero.astro';
import ToolHowItWorks from '../../../components/tools/ToolHowItWorks.astro';
import SharedPricing from '../../../components/shared/SharedPricing.astro';
import WhatsAppButton from '../../../components/WhatsAppButton.astro';
import { getToolBySlug } from '../../../config/tools';

const tool = getToolBySlug('arrendamiento')!;
---

<Layout
    title="Contrato de Arrendamiento · Grexia"
    navbarVariant="tool-landing"
    navbarActiveTool="arrendamiento"
>
    <ToolHero tool={tool} />
    <ToolHowItWorks tool={tool} />
    <SharedPricing />
    <WhatsAppButton />
</Layout>
