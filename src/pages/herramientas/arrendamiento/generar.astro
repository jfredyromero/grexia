---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/shared/Navbar.astro';
import WhatsAppButton from '../../../components/WhatsAppButton.astro';
import ArrendamientoForm from '../../../components/arrendamiento/ArrendamientoForm';
---

<Layout title="Generador de Contrato de Arrendamiento · Lexia">
    <Navbar
        variant="tool-form"
        activeTool="arrendamiento"
    />
    <main class="flex-grow w-full bg-background-light">
        <div class="mx-auto max-w-7xl px-6 lg:px-8 py-8 lg:py-14">
            <!-- Page header -->
            <div class="mb-8">
                <a
                    href="/herramientas/arrendamiento"
                    class="inline-flex items-center gap-1 text-sm text-slate-500 hover:text-secondary transition-colors"
                >
                    <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                    Ver detalles
                </a>
                <h1 class="text-3xl font-black text-secondary mt-3">Genera tu contrato de arrendamiento</h1>
                <div class="flex flex-wrap gap-3 mt-2">
                    <span class="inline-flex items-center gap-1 text-xs font-semibold text-slate-500">
                        <span class="material-symbols-outlined text-primary text-[16px]">check_circle</span>
                        Gratis
                    </span>
                    <span class="inline-flex items-center gap-1 text-xs font-semibold text-slate-500">
                        <span class="material-symbols-outlined text-primary text-[16px]">check_circle</span>
                        Sin registro
                    </span>
                    <span class="inline-flex items-center gap-1 text-xs font-semibold text-slate-500">
                        <span class="material-symbols-outlined text-primary text-[16px]">check_circle</span>
                        Válido en Colombia · Ley 820 de 2003
                    </span>
                </div>
            </div>

            <!-- React island: full form with internal 2-col layout -->
            <ArrendamientoForm client:load />
        </div>
    </main>
    <WhatsAppButton />
</Layout>
