---
import Layout from '../../../layouts/Layout.astro';
import ToolHero from '../../../components/tools/ToolHero.astro';
import ToolHowItWorks from '../../../components/tools/ToolHowItWorks.astro';
import SharedPricing from '../../../components/shared/SharedPricing.astro';
import WhatsAppButton from '../../../components/WhatsAppButton.astro';
import TutelaSelector from '../../../components/tutela/TutelaSelector';
import { getToolBySlug } from '../../../config/tools';

const tool = getToolBySlug('tutela')!;
---

<Layout
    title="Generador de Tutela de Salud · Grexia"
    navbarVariant="tool-landing"
    navbarActiveTool="tutela"
>
    <ToolHero tool={tool} />

    <!-- Selector de temática -->
    <section class="py-8 lg:py-14 bg-background-light">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="mb-8">
                <h2 class="text-2xl font-black text-secondary mb-2">¿Sobre qué tema es tu tutela?</h2>
                <p class="text-slate-500">
                    Selecciona la temática para generar tu documento. Por ahora tenemos disponible la tutela de salud.
                </p>
            </div>
            <TutelaSelector client:only="react" />
        </div>
    </section>

    <ToolHowItWorks tool={tool} />
    <SharedPricing />
    <WhatsAppButton />
</Layout>
