---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/shared/Navbar.astro';
import ToolHero from '../../../components/tools/ToolHero.astro';
import ToolHowItWorks from '../../../components/tools/ToolHowItWorks.astro';
import SharedPricing from '../../../components/shared/SharedPricing.astro';
import WhatsAppButton from '../../../components/WhatsAppButton.astro';
import { getToolBySlug } from '../../../config/tools';

const tool = getToolBySlug('compraventa')!;
---

<Layout title="Promesa de Compraventa Gratis · Grexia">
    <Navbar
        variant="tool-landing"
        activeTool="compraventa"
    />
    <ToolHero tool={tool} />
    <ToolHowItWorks tool={tool} />
    <SharedPricing />
    <WhatsAppButton />
</Layout>
