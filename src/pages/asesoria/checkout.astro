---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/shared/Breadcrumb.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import CheckoutForm from '../../components/asesoria/Checkout';

const base = import.meta.env.BASE_URL;

const SESSION_FEATURES = [
    { icon: 'schedule', text: '45 minutos de sesión virtual' },
    { icon: 'person', text: 'Abogado especialista en tu área' },
    { icon: 'chat', text: 'Diagnóstico y hoja de ruta de tu caso' },
    { icon: 'verified', text: 'Sesión grabada y enviada a tu email' },
];
---

<Layout title="Checkout · Asesoría Legal · Grexia">
    <main class="grow w-full bg-background-light">
        <div class="mx-auto max-w-4xl px-6 lg:px-8 py-8 lg:py-14">
            <!-- Breadcrumb -->
            <div class="mb-8">
                <Breadcrumb items={[{ label: 'Inicio', href: base }, { label: 'Asesoría legal' }]} />
                <h1 class="text-3xl font-black text-secondary mt-4">Agenda tu asesoría legal</h1>
                <p class="mt-1.5 text-slate-500">Sesión virtual de 45 minutos · $59.900 COP · Pago único</p>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 items-start">
                <!-- ── Left: order summary ─────────────────────────────────── -->
                <aside class="lg:col-span-2 lg:sticky lg:top-28">
                    <div
                        class="relative flex flex-col gap-6 rounded-lg bg-secondary p-6 overflow-hidden shadow-xl shadow-secondary/20 ring-2 ring-primary"
                    >
                        <div
                            class="absolute -top-16 -right-16 h-48 w-48 rounded-full bg-primary/10 blur-2xl pointer-events-none"
                        >
                        </div>

                        <div class="relative">
                            <span
                                class="inline-flex items-center rounded-full bg-white/15 px-3 py-1 text-xs font-bold uppercase tracking-wide text-white"
                            >
                                ★ Asesoría puntual
                            </span>
                            <h2 class="mt-3 text-xl font-black text-white">Sesión con abogado especialista</h2>
                        </div>

                        <div class="relative flex items-end gap-1.5">
                            <span class="text-4xl font-black text-white">$59.900</span>
                            <span class="text-sm text-slate-300 pb-1">COP · pago único</span>
                        </div>

                        <ul class="relative flex flex-col gap-3">
                            {
                                SESSION_FEATURES.map((f) => (
                                    <li class="flex items-center gap-3 text-sm text-slate-300">
                                        <span class="material-symbols-outlined text-blue-400 text-[18px] shrink-0">
                                            {f.icon}
                                        </span>
                                        {f.text}
                                    </li>
                                ))
                            }
                        </ul>

                        <div class="relative border-t border-white/10 pt-4 flex items-center gap-3">
                            <span class="material-symbols-outlined text-slate-400 text-[18px] shrink-0">lock</span>
                            <p class="text-xs text-slate-400 leading-relaxed">
                                Pago seguro procesado por <strong class="text-slate-300">ePayco</strong>. Tu información
                                está protegida.
                            </p>
                        </div>
                    </div>
                </aside>

                <!-- ── Right: form + payment (React island) ───────────────── -->
                <div class="lg:col-span-3">
                    <CheckoutForm client:only="react" />
                </div>
            </div>
        </div>
    </main>

    <WhatsAppButton />
</Layout>

<!-- ePayco SDK — cargado a nivel de página para que esté disponible cuando React hidrate -->
<script
    defer
    src="https://checkout.epayco.co/checkout.js"
></script>
