---
import Layout from '../../layouts/Layout.astro';
import SharedPricing from '../../components/shared/SharedPricing.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="Planes · Grexia | Documentos Legales para Colombia">
    <main class="grow w-full">
        <!-- ─── HERO ──────────────────────────────────────────────────────── -->
        <section class="bg-white pt-14 pb-0 lg:pt-20">
            <div class="mx-auto max-w-4xl px-6 lg:px-8 text-center">
                <h1 class="text-4xl font-black tracking-tight text-secondary sm:text-5xl lg:text-6xl leading-tight">
                    Elige el plan ideal para<br class="hidden sm:block" />
                    <span class="relative whitespace-nowrap">
                        tu seguridad legal
                        <span class="absolute bottom-1 left-0 h-3 w-full bg-primary/40 rounded-full"></span>
                    </span>
                </h1>
                <p class="mx-auto mt-8 max-w-xl text-lg text-slate-600">
                    Genera contratos, tutelas, pagarés y más sin registro y sin costo. Cuando necesites orientación
                    legal real, estamos a una sesión de distancia.
                </p>
            </div>
        </section>

        <!-- ─── #PLANES — SharedPricing ──────────────────────────────────── -->
        <div
            id="precios"
            class="scroll-mt-24"
        >
            <SharedPricing showHeader={false} />
        </div>

        <!-- ─── #COMO-FUNCIONA ────────────────────────────────────────────── -->
        <section
            id="como-funciona"
            class="w-full bg-neutral-50 py-16 lg:py-24 scroll-mt-24"
        >
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <div class="text-center mb-14">
                    <h2 class="text-3xl font-black tracking-tight text-secondary sm:text-4xl">
                        ¿Cómo funciona cada plan?
                    </h2>
                    <p class="mt-3 text-lg text-slate-600 max-w-lg mx-auto">Dos caminos según lo que necesitas.</p>
                </div>

                <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
                    <!-- Plan Gratis -->
                    <div class="rounded-lg border border-slate-200 bg-white p-8 shadow-sm">
                        <div class="flex items-center gap-3 mb-8">
                            <span class="material-symbols-outlined text-[22px] text-primary">description</span>
                            <h3 class="text-xl font-black text-secondary">Plan Gratis</h3>
                            <span class="ml-auto rounded-full bg-slate-100 px-3 py-1 text-xs font-bold text-slate-600">
                                $0
                            </span>
                        </div>

                        <ol class="flex flex-col gap-6">
                            <li class="flex items-start gap-4">
                                <span
                                    class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-black text-white"
                                >
                                    1
                                </span>
                                <div>
                                    <p class="font-bold text-secondary">Elige la herramienta</p>
                                    <p class="mt-0.5 text-sm text-slate-600">
                                        Contrato de arrendamiento, pagaré, tutela, contrato laboral y más.
                                    </p>
                                </div>
                            </li>
                            <li class="flex items-start gap-4">
                                <span
                                    class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-black text-white"
                                >
                                    2
                                </span>
                                <div>
                                    <p class="font-bold text-secondary">Completa el formulario</p>
                                    <p class="mt-0.5 text-sm text-slate-600">
                                        Responde las preguntas guiadas. Sin tecnicismos legales.
                                    </p>
                                </div>
                            </li>
                            <li class="flex items-start gap-4">
                                <span
                                    class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-black text-white"
                                >
                                    3
                                </span>
                                <div>
                                    <p class="font-bold text-secondary">Descarga tu PDF</p>
                                    <p class="mt-0.5 text-sm text-slate-600">
                                        Listo al instante, sin registro, sin tarjeta. Con marca de agua Grexia.
                                    </p>
                                </div>
                            </li>
                        </ol>

                        <a
                            href={base + 'herramientas'}
                            class="mt-8 flex h-11 items-center justify-center gap-1.5 rounded-full bg-primary text-sm font-bold text-white shadow-md shadow-primary/20 transition-all hover:bg-primary-hover hover:-translate-y-px"
                        >
                            Empezar gratis
                            <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                        </a>
                    </div>

                    <!-- Asesoría Legal -->
                    <div
                        class="rounded-lg bg-secondary p-8 shadow-xl shadow-secondary/25 ring-2 ring-primary relative overflow-hidden"
                    >
                        <div
                            class="absolute -top-16 -right-16 h-48 w-48 rounded-full bg-primary/10 blur-2xl pointer-events-none"
                        >
                        </div>

                        <div class="relative flex items-center gap-3 mb-8">
                            <span class="material-symbols-outlined text-[22px] text-blue-400">gavel</span>
                            <h3 class="text-xl font-black text-white">Asesoría Legal</h3>
                            <span class="ml-auto rounded-full bg-white/15 px-3 py-1 text-xs font-bold text-white">
                                $59.900
                            </span>
                        </div>

                        <ol class="relative flex flex-col gap-6">
                            <li class="flex items-start gap-4">
                                <span
                                    class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-black text-white"
                                >
                                    1
                                </span>
                                <div>
                                    <p class="font-bold text-white">Agenda tu sesión</p>
                                    <p class="mt-0.5 text-sm text-slate-300">
                                        Elige el horario que mejor te quede. Primera sesión a precio fijo.
                                    </p>
                                </div>
                            </li>
                            <li class="flex items-start gap-4">
                                <span
                                    class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-black text-white"
                                >
                                    2
                                </span>
                                <div>
                                    <p class="font-bold text-white">Habla con un abogado especialista</p>
                                    <p class="mt-0.5 text-sm text-slate-300">
                                        Sesión de estudio de viabilidad y diagnóstico de tu caso.
                                    </p>
                                </div>
                            </li>
                            <li class="flex items-start gap-4">
                                <span
                                    class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-black text-white"
                                >
                                    3
                                </span>
                                <div>
                                    <p class="font-bold text-white">Recibe tu hoja de ruta legal</p>
                                    <p class="mt-0.5 text-sm text-slate-300">
                                        Diagnóstico claro y próximos pasos concretos para tu situación.
                                    </p>
                                </div>
                            </li>
                        </ol>

                        <a
                            href={base + 'asesoria/checkout'}
                            class="relative mt-8 flex h-11 items-center justify-center gap-1.5 rounded-full bg-primary text-sm font-bold text-white shadow-md shadow-primary/20 transition-all hover:bg-primary-hover hover:-translate-y-px"
                        >
                            Agendar primera sesión
                            <span class="material-symbols-outlined text-[18px]">calendar_month</span>
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <!-- ─── #COMPARACION ──────────────────────────────────────────────── -->
        <section
            id="comparacion"
            class="w-full bg-white py-16 lg:py-24 scroll-mt-24"
        >
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <div class="text-center mb-14">
                    <h2 class="text-3xl font-black tracking-tight text-secondary sm:text-4xl">Comparación de planes</h2>
                    <p class="mt-3 text-lg text-slate-600 max-w-lg mx-auto">Todo lo que necesitas saber para elegir.</p>
                </div>

                <!-- Tabla — scroll horizontal en mobile -->
                <div class="overflow-x-auto rounded-lg border border-slate-200 shadow-sm">
                    <table class="w-full min-w-160 border-collapse text-sm">
                        <thead>
                            <tr>
                                <th
                                    class="border-b border-slate-200 bg-slate-50 px-6 py-4 text-left text-xs font-bold uppercase tracking-wide text-slate-500"
                                >
                                    Feature
                                </th>
                                <th
                                    class="border-b border-slate-200 bg-slate-50 px-6 py-4 text-center text-xs font-bold uppercase tracking-wide text-slate-700"
                                >
                                    Gratis
                                </th>
                                <th
                                    class="border-b border-primary bg-secondary px-6 py-4 text-center text-xs font-bold uppercase tracking-wide text-white"
                                >
                                    Asesoría
                                </th>
                                <th
                                    class="border-b border-slate-200 bg-slate-50 px-6 py-4 text-center text-xs font-bold uppercase tracking-wide text-slate-700"
                                >
                                    Empresarial
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Generación de documentos -->
                            <tr class="border-b border-slate-100">
                                <td class="px-6 py-4 font-medium text-slate-700">Generación de documentos</td>
                                <td class="px-6 py-4 text-center">
                                    <span class="material-symbols-outlined text-[18px] text-primary">check_circle</span>
                                    <span class="sr-only">Ilimitada</span>
                                    <p class="mt-0.5 text-xs text-slate-500">Ilimitada</p>
                                </td>
                                <td class="bg-secondary/5 px-6 py-4 text-center">
                                    <span class="material-symbols-outlined text-[18px] text-primary">check_circle</span>
                                    <p class="mt-0.5 text-xs text-slate-500">Ilimitada</p>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <span class="material-symbols-outlined text-[18px] text-primary">check_circle</span>
                                    <p class="mt-0.5 text-xs text-slate-500">Ilimitada</p>
                                </td>
                            </tr>

                            <!-- Marca de agua -->
                            <tr class="border-b border-slate-100">
                                <td class="px-6 py-4 font-medium text-slate-700">Marca de agua</td>
                                <td class="px-6 py-4 text-center">
                                    <span class="material-symbols-outlined text-[18px] text-amber-400">warning</span>
                                    <p class="mt-0.5 text-xs text-slate-500">Siempre</p>
                                </td>
                                <td class="bg-secondary/5 px-6 py-4 text-center">
                                    <span class="material-symbols-outlined text-[18px] text-amber-400">warning</span>
                                    <p class="mt-0.5 text-xs text-slate-500">Siempre</p>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <span class="material-symbols-outlined text-[18px] text-primary">check_circle</span>
                                    <p class="mt-0.5 text-xs text-slate-500">Sin marca</p>
                                </td>
                            </tr>

                            <!-- Asesoría legal -->
                            <tr class="border-b border-slate-100">
                                <td class="px-6 py-4 font-medium text-slate-700">Asesoría legal</td>
                                <td class="px-6 py-4 text-center">
                                    <span class="material-symbols-outlined text-[18px] text-slate-300">cancel</span>
                                </td>
                                <td class="bg-secondary/5 px-6 py-4 text-center">
                                    <span class="material-symbols-outlined text-[18px] text-primary">check_circle</span>
                                    <p class="mt-0.5 text-xs text-slate-500">Por caso</p>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <span class="material-symbols-outlined text-[18px] text-primary">check_circle</span>
                                    <p class="mt-0.5 text-xs text-slate-500">Prioritaria</p>
                                </td>
                            </tr>

                            <!-- Templates personalizados -->
                            <tr class="border-b border-slate-100">
                                <td class="px-6 py-4 font-medium text-slate-700">Templates personalizados</td>
                                <td class="px-6 py-4 text-center">
                                    <span class="material-symbols-outlined text-[18px] text-slate-300">cancel</span>
                                </td>
                                <td class="bg-secondary/5 px-6 py-4 text-center">
                                    <span class="material-symbols-outlined text-[18px] text-slate-300">cancel</span>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <span class="material-symbols-outlined text-[18px] text-primary">check_circle</span>
                                    <p class="mt-0.5 text-xs text-slate-500">Con tu logo</p>
                                </td>
                            </tr>

                            <!-- Múltiples usuarios -->
                            <tr class="border-b border-slate-100">
                                <td class="px-6 py-4 font-medium text-slate-700">Múltiples usuarios</td>
                                <td class="px-6 py-4 text-center">
                                    <span class="material-symbols-outlined text-[18px] text-slate-300">cancel</span>
                                </td>
                                <td class="bg-secondary/5 px-6 py-4 text-center">
                                    <span class="material-symbols-outlined text-[18px] text-slate-300">cancel</span>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <span class="material-symbols-outlined text-[18px] text-primary">check_circle</span>
                                </td>
                            </tr>

                            <!-- Soporte -->
                            <tr class="border-b border-slate-100">
                                <td class="px-6 py-4 font-medium text-slate-700">Soporte</td>
                                <td class="px-6 py-4 text-center text-xs text-slate-600">Comunidad</td>
                                <td class="bg-secondary/5 px-6 py-4 text-center text-xs text-slate-600">Email</td>
                                <td class="px-6 py-4 text-center text-xs text-slate-600">Prioritario</td>
                            </tr>

                            <!-- Precio -->
                            <tr>
                                <td class="px-6 py-4 font-bold text-slate-700">Precio</td>
                                <td class="px-6 py-4 text-center font-black text-secondary">$0</td>
                                <td class="bg-secondary/5 px-6 py-4 text-center">
                                    <span class="font-black text-secondary">$59.900</span>
                                    <p class="text-xs text-slate-500">primera sesión</p>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <span class="font-black text-secondary">$119.000</span>
                                    <p class="text-xs text-slate-500">/mes</p>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    </main>

    <WhatsAppButton />
</Layout>
