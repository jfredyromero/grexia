---
import '../styles/global.css';
import Footer from '../components/shared/Footer.astro';
import CTAFinal from '../components/shared/CTAFinal.astro';
import Navbar from '../components/shared/Navbar.astro';
import { ClientRouter } from 'astro:transitions';
import type { ToolSlug } from '../config/tools';

interface Props {
    title?: string;
    description?: string;
    canonical?: string;
    schema?: Record<string, unknown>;
    navbarVariant?: 'home' | 'tool-landing' | 'tool-form';
    navbarActiveTool?: ToolSlug;
}

const {
    title = 'Grexia - LegalTech Colombia',
    description,
    canonical,
    schema,
    navbarVariant = 'home',
    navbarActiveTool,
} = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1.0"
        />
        <link
            rel="icon"
            type="image/svg+xml"
            href={base + 'logo.svg'}
        />
        <meta
            name="generator"
            content={Astro.generator}
        />
        <title>{title}</title>
        {
            description && (
                <meta
                    name="description"
                    content={description}
                />
            )
        }
        {
            canonical && (
                <link
                    rel="canonical"
                    href={canonical}
                />
            )
        }
        {
            schema && (
                <script
                    type="application/ld+json"
                    set:html={JSON.stringify(schema)}
                />
            )
        }
        <link
            rel="preconnect"
            href="https://fonts.googleapis.com"
        />
        <link
            rel="preconnect"
            href="https://fonts.gstatic.com"
            crossorigin
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Montserrat:wght@700;800&display=swap"
            rel="stylesheet"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
            rel="stylesheet"
        />
        <ClientRouter />
    </head>
    <body class="bg-background-light text-slate-900 overflow-x-hidden relative min-h-screen flex flex-col">
        <Navbar
            transition:animate="none"
            variant={navbarVariant}
            activeTool={navbarActiveTool}
        />
        <slot />
        <CTAFinal />
        <Footer />
    </body>
</html>
